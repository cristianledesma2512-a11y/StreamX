<!DOCTYPE html>
<html lang="es" class="dark">
<head><%- include('../partials/head', { title: series.title + ' — Editar' }) %></head>
<body class="bg-zinc-950 text-zinc-100 min-h-screen flex antialiased">
<%- include('partials/nav') %>

<div class="flex-1 overflow-y-auto">
  <div class="max-w-5xl mx-auto px-6 py-8">

    <!-- Header -->
    <div class="flex items-center gap-3 mb-6">
      <a href="/admin/series" class="text-zinc-500 hover:text-white transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </a>
      <h1 class="text-xl font-bold text-white truncate"><%= series.title %></h1>
      <span class="text-xs text-zinc-500 shrink-0"><%= series.totalSeasons || 0 %> temp.</span>
    </div>

    <% if (typeof msg !== 'undefined' && msg) { %>
    <div class="mb-4 rounded-lg bg-green-950/50 border border-green-800 px-4 py-3 text-sm text-green-300"><%= msg %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="mb-4 rounded-lg bg-red-950/50 border border-red-800 px-4 py-3 text-sm text-red-300"><%= error %></div>
    <% } %>

    <!-- Layout: sidebar + contenido -->
    <div class="flex gap-6">

      <!-- Sidebar: poster + datos básicos -->
      <div class="w-48 shrink-0 space-y-4">
        <% if (series.posterPath) { %>
        <img src="<%= series.posterPath %>" alt="" class="w-full rounded-xl border border-zinc-800 object-cover" />
        <% } else { %>
        <div class="aspect-[2/3] rounded-xl border border-dashed border-zinc-700 flex items-center justify-center">
          <p class="text-xs text-zinc-600">Sin poster</p>
        </div>
        <% } %>
        <p class="text-xs text-zinc-600">TMDB: <%= series.tmdbId %></p>
        <p class="text-xs text-zinc-600"><%= series.viewCount || 0 %> vistas</p>
        <% if (series.genres && series.genres.length > 0) { %>
        <div class="flex flex-wrap gap-1">
          <% series.genres.forEach(function(g) { %>
          <span class="text-[10px] bg-zinc-800 text-zinc-400 px-1.5 py-0.5 rounded"><%= g %></span>
          <% }); %>
        </div>
        <% } %>
      </div>

      <!-- Contenido principal -->
      <div class="flex-1 min-w-0 space-y-5">

        <!-- Datos generales -->
        <div class="rounded-xl border border-zinc-800 bg-zinc-900/60 p-5">
          <h2 class="text-sm font-semibold text-white mb-4">Datos de la serie</h2>
          <form method="POST" action="/admin/series/<%= series._id %>/update" class="space-y-3">
            <div class="grid grid-cols-2 gap-3">
              <div class="col-span-2">
                <label class="block text-xs text-zinc-400 mb-1">Título</label>
                <input type="text" name="title" value="<%= series.title %>" required
                  class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-blue-500 transition" />
              </div>
              <div>
                <label class="block text-xs text-zinc-400 mb-1">Primera emisión</label>
                <input type="text" name="firstAirDate" value="<%= series.firstAirDate %>"
                  class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-blue-500 transition" />
              </div>
              <div>
                <label class="block text-xs text-zinc-400 mb-1">Poster URL</label>
                <input type="text" name="posterPath" value="<%= series.posterPath %>"
                  class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-blue-500 transition" />
              </div>
              <div class="col-span-2">
                <label class="block text-xs text-zinc-400 mb-1">Sinopsis</label>
                <textarea name="overview" rows="2"
                  class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-blue-500 transition resize-none"><%= series.overview %></textarea>
              </div>
              <div class="flex items-center gap-5 flex-wrap">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="featured" class="rounded border-zinc-600 bg-zinc-800 text-violet-500" <%= series.featured ? 'checked' : '' %> />
                  <span class="text-sm text-zinc-300">Destacada</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="active" value="on" class="rounded border-zinc-600 bg-zinc-800 text-emerald-500" <%= series.active !== false ? 'checked' : '' %> />
                  <span class="text-sm text-zinc-300">Activa</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer" title="Usar Vimeus como servidor automático">
                  <input type="checkbox" name="vimeusEnabled" value="on" class="rounded border-zinc-600 bg-zinc-800 text-emerald-400" <%= series.vimeusEnabled !== false ? 'checked' : '' %> />
                  <span class="text-sm text-zinc-300 flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-emerald-400 inline-block"></span>Vimeus
                  </span>
                </label>
              </div>
            </div>
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition">
              Guardar cambios
            </button>
          </form>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- TEMPORADAS Y EPISODIOS                                         -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <% var seasons = (series.seasons && Array.isArray(series.seasons)) ? series.seasons : []; %>
        <% var activeSeason = parseInt(typeof query !== 'undefined' && query && query.season ? query.season : '') || (seasons.length > 0 ? seasons[0].number : 0); %>

        <div class="rounded-xl border border-zinc-800 bg-zinc-900/60">
          <div class="px-5 py-4 border-b border-zinc-800 flex items-center justify-between">
            <h2 class="text-sm font-semibold text-white">Temporadas y Episodios</h2>
            <span class="text-xs text-zinc-500"><%= seasons.length %> temp. importadas</span>
          </div>

          <% if (seasons.length === 0) { %>
          <div class="p-8 text-center">
            <p class="text-sm text-zinc-500 mb-3">Sin temporadas. Re-importá la serie desde TMDB para cargar los episodios.</p>
            <form method="POST" action="/admin/series/import" class="inline-flex gap-2">
              <input type="hidden" name="tmdbId" value="<%= series.tmdbId %>" />
              <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition">
                Re-importar desde TMDB
              </button>
            </form>
          </div>
          <% } else { %>

          <!-- Tabs de temporadas -->
          <div class="flex overflow-x-auto gap-1 px-4 pt-4 pb-0 border-b border-zinc-800">
            <% seasons.forEach(function(season) { %>
            <a href="/admin/series/<%= series._id %>/edit?season=<%= season.number %>"
              class="shrink-0 px-3 py-2 text-xs font-semibold rounded-t-lg border-b-2 transition whitespace-nowrap
                <%= activeSeason === season.number
                    ? 'border-blue-500 text-blue-400 bg-blue-950/30'
                    : 'border-transparent text-zinc-500 hover:text-white hover:border-zinc-600' %>">
              T<%= season.number %>
              <% var linkedEps = season.episodes.filter(function(e){ return e.links && e.links.length > 0; }).length; %>
              <span class="ml-1 text-[9px] <%= linkedEps > 0 ? 'text-emerald-400' : 'text-zinc-600' %>">
                (<%= linkedEps %>/<%= season.episodes.length %>)
              </span>
            </a>
            <% }); %>
          </div>

          <!-- Contenido de la temporada activa -->
          <% var currentSeason = seasons.find(function(s){ return s.number === activeSeason; }) || seasons[0]; %>
          <% if (currentSeason) { %>
          <div class="p-4">
            <div class="flex items-center justify-between mb-3">
              <div>
                <p class="text-sm font-semibold text-white"><%= currentSeason.title || 'Temporada ' + currentSeason.number %></p>
                <% if (currentSeason.airDate) { %><p class="text-xs text-zinc-500"><%= currentSeason.airDate %></p><% } %>
              </div>
              <span class="text-xs text-zinc-500"><%= currentSeason.episodes.length %> episodios</span>
            </div>

            <!-- Lista de episodios -->
            <div class="space-y-2">
              <% currentSeason.episodes.forEach(function(ep) { %>
              <details class="group rounded-lg border border-zinc-800 bg-zinc-900/40 hover:border-zinc-700 transition">
                <summary class="flex items-center gap-3 px-4 py-3 cursor-pointer list-none select-none">
                  <!-- Numero y titulo -->
                  <span class="w-8 h-8 shrink-0 rounded-lg bg-zinc-800 flex items-center justify-center text-xs font-bold text-zinc-400">
                    <%= ep.number %>
                  </span>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-white truncate"><%= ep.title || 'Episodio ' + ep.number %></p>
                    <% if (ep.airDate) { %><p class="text-xs text-zinc-600"><%= ep.airDate %></p><% } %>
                  </div>
                  <!-- Links badge -->
                  <% var epLinks = (ep.links && Array.isArray(ep.links)) ? ep.links : []; %>
                  <span class="shrink-0 text-xs font-bold px-2 py-1 rounded-full
                    <%= epLinks.length > 0 ? 'bg-emerald-900/50 text-emerald-400' : 'bg-zinc-800 text-zinc-600' %>">
                    <%= epLinks.length %> link<%= epLinks.length !== 1 ? 's' : '' %>
                  </span>
                  <svg class="w-4 h-4 text-zinc-600 group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>

                <!-- Detalle del episodio -->
                <div class="px-4 pb-4 pt-2 border-t border-zinc-800/50">
                  <% if (ep.overview) { %>
                  <p class="text-xs text-zinc-500 mb-3 leading-relaxed"><%= ep.overview %></p>
                  <% } %>

                  <!-- Links existentes -->
                  <% if (epLinks.length > 0) { %>
                  <div class="space-y-1.5 mb-3">
                    <% epLinks.forEach(function(link, li) { %>
                    <div class="flex items-center gap-2 bg-zinc-800/60 rounded-lg px-3 py-2">
                      <div class="flex-1 min-w-0">
                        <span class="text-xs font-medium text-white"><%= link.serverName %></span>
                        <% if (link.quality) { %><span class="ml-1.5 text-[9px] bg-zinc-700 text-zinc-400 px-1 rounded font-bold"><%= link.quality %></span><% } %>
                        <% if (link.language) { %><span class="ml-1 text-[10px] text-zinc-500"><%= link.language %></span><% } %>
                        <p class="text-[10px] text-zinc-700 truncate"><%= link.url.slice(0, 55) %>...</p>
                      </div>
                      <form method="POST"
                        action="/admin/series/<%= series._id %>/seasons/<%= currentSeason._id %>/episodes/<%= ep._id %>/links/<%= li %>/remove">
                        <button type="submit" class="text-red-500 hover:text-red-400 text-xs px-1.5 py-1 rounded hover:bg-red-950/30 transition"
                          onclick="return confirm('¿Eliminar este enlace?')">✕</button>
                      </form>
                    </div>
                    <% }); %>
                  </div>
                  <% } %>

                  <!-- Formulario agregar link -->
                  <form method="POST"
                    action="/admin/series/<%= series._id %>/seasons/<%= currentSeason._id %>/episodes/<%= ep._id %>/links"
                    class="grid grid-cols-2 gap-2">
                    <input type="text" name="serverName" placeholder="Servidor (ej: Servidor 1)" required
                      class="bg-zinc-900 border border-zinc-700 rounded-lg px-2.5 py-1.5 text-xs text-white focus:outline-none focus:border-blue-500 transition placeholder-zinc-600" />
                    <select name="quality" class="bg-zinc-900 border border-zinc-700 rounded-lg px-2.5 py-1.5 text-xs text-white focus:outline-none focus:border-blue-500 transition">
                      <option value="">— Calidad</option>
                      <option value="SD">SD</option>
                      <option value="HD">HD</option>
                      <option value="FHD">Full HD</option>
                      <option value="4K">4K</option>
                    </select>
                    <input type="text" name="language" value="Latino" placeholder="Idioma"
                      class="bg-zinc-900 border border-zinc-700 rounded-lg px-2.5 py-1.5 text-xs text-white focus:outline-none focus:border-blue-500 transition" />
                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold px-3 py-1.5 rounded-lg transition">
                      + Agregar
                    </button>
                    <div class="col-span-2">
                      <input type="url" name="url" placeholder="https://... (URL del iframe)" required
                        class="w-full bg-zinc-900 border border-zinc-700 rounded-lg px-2.5 py-1.5 text-xs text-white focus:outline-none focus:border-blue-500 transition placeholder-zinc-600" />
                    </div>
                  </form>
                </div>
              </details>
              <% }); %>
            </div>
          </div>
          <% } %>

          <% } %>
        </div>

        <!-- Zona peligrosa -->
        <div class="rounded-xl border border-red-900/40 bg-red-950/10 p-5">
          <h2 class="text-sm font-semibold text-red-400 mb-3">Zona peligrosa</h2>
          <form method="POST" action="/admin/series/<%= series._id %>/delete"
            onsubmit="return confirm('¿Eliminar «<%= series.title %>» definitivamente?')">
            <button type="submit" class="bg-red-700 hover:bg-red-600 text-white text-sm font-semibold px-4 py-2 rounded-lg transition">
              Eliminar serie
            </button>
          </form>
        </div>

      </div><!-- fin contenido principal -->
    </div><!-- fin layout -->
  </div>
</div>
</body>
</html>
