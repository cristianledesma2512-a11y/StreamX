      <div class="cat-pill aire" onclick="filtrarCat('AIRE',this)">📺 AIRE</div>
      <div class="cat-pill mus" onclick="filtrarCat('MUSICA',this)">🎵 MÚSICA</div>
      <div class="cat-pill inf" onclick="filtrarCat('INFANTIL',this)">👦 INFANTIL</div>
