function registrarPresencia(nick) {
  // Verificar blacklist primero
  db.ref("blacklist/" + nick).once("value", snap => {
    if (snap.exists() && snap.val() === true) {
      // Usuario baneado
      document.body.innerHTML = `
        <div style="position:fixed;inset:0;background:#09090b;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;color:#f4f4f5;">
          <div style="font-size:60px;">🚫</div>
          <h1 style="color:#e74c3c;font-size:24px;">Acceso bloqueado</h1>
          <p style="color:#71717a;font-size:14px;">Tu usuario ha sido baneado de TV en Vivo.</p>
          <p style="color:#71717a;font-size:12px;">Si creés que es un error, contactá al administrador.</p>
        </div>`;
      return;
    }
    // Registrar presencia online
    const statusRef = db.ref("status/" + nick);
    statusRef.set({ online: true, ts: firebase.database.ServerValue.TIMESTAMP });
    statusRef.onDisconnect().remove();
    // Incrementar visitas
    db.ref("stats/visitas_totales").transaction(v => (v || 0) + 1);
  });
}

// Si ya tiene nick registrado, verificar blacklist al cargar
if (miNick) {
  db.ref("blacklist/" + miNick).once("value", snap => {
    if (snap.exists() && snap.val() === true) {
      document.body.innerHTML = `
        <div style="position:fixed;inset:0;background:#09090b;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;color:#f4f4f5;">
          <div style="font-size:60px;">🚫</div>
          <h1 style="color:#e74c3c;font-size:24px;">Acceso bloqueado</h1>
          <p style="color:#71717a;font-size:14px;">Tu usuario ha sido baneado de TV en Vivo.</p>
        </div>`;
      return;
    }
    // Registrar presencia
    const statusRef = db.ref("status/" + miNick);
    statusRef.set({ online: true, ts: firebase.database.ServerValue.TIMESTAMP });
    statusRef.onDisconnect().remove();
    // Incrementar visitas
    db.ref("stats/visitas_totales").transaction(v => (v || 0) + 1);
  });
}


function saltearModal() {
  const autoNick = "Invitado" + Math.floor(Math.random()*9000+1000);
  localStorage.setItem("mnv_nick", autoNick); miNick = autoNick;
  document.getElementById("modal-nick").style.display = "none";
  document.getElementById("user-badge").textContent = "IV";
  registrarPresencia(autoNick);
}

