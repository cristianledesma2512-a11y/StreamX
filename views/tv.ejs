function renderGruposConmebol(elId, grupos, icon) {
  const el = document.getElementById(elId); if(!el) return;
  el.style.padding="8px 0";
  if(!Object.keys(grupos).length){el.innerHTML='<p style="color:var(--muted);text-align:center;padding:30px;">⏳ Cargando grupos...</p>';return;}
  const grid=document.createElement("div");grid.className="grupos-grid";
  Object.entries(grupos).sort((a,b)=>a[0].localeCompare(b[0])).forEach(([grupo,data])=>{
    const eqs=data.equipos||[];
    const card=document.createElement("div");card.className="grupo-card";
    card.innerHTML=`<div class="grupo-hdr"><div class="grupo-title">GRUPO ${grupo}</div><span>${icon}</span></div>`;
    const body=document.createElement("div");body.className="grupo-body";
    eqs.forEach((eq,i)=>{
      const row=document.createElement("div");row.className="grupo-eq"+(i<2?" top":"");
