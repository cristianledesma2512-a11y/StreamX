<!DOCTYPE html>
<html lang="es" class="dark">
<head><%- include('../partials/head', { title: 'Películas — StreamX Admin' }) %></head>
<body class="bg-zinc-950 text-zinc-100 min-h-screen flex antialiased">
<%- include('partials/nav') %>

<div class="flex-1 overflow-y-auto">
  <div class="max-w-6xl mx-auto px-6 py-8">

    <div class="flex items-center justify-between mb-6">
      <h1 class="text-xl font-bold text-white">Películas <span class="text-zinc-500 font-normal text-base">(<%= movies.length %>)</span></h1>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
    <div class="mb-4 rounded-lg bg-red-950/50 border border-red-800 px-4 py-3 text-sm text-red-300"><%= error %></div>
    <% } %>
    <% if (typeof msg !== 'undefined' && msg) { %>
    <div class="mb-4 rounded-lg bg-green-950/50 border border-green-800 px-4 py-3 text-sm text-green-300"><%= msg %></div>
    <% } %>

    <div class="rounded-xl border border-zinc-800 bg-zinc-900/60 p-4 mb-6 shadow-sm">
      <p class="text-xs text-zinc-500 font-medium mb-3 uppercase tracking-wider text-[10px]">Importar desde TMDB</p>
      <form method="POST" action="/admin/movies/import" class="flex gap-2">
        <input type="number" name="tmdbId" placeholder="ID de TMDB (ej: 27205)" required
          class="flex-1 max-w-xs bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition placeholder-zinc-600" />
        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Importar
        </button>
      </form>
    </div>

    <form method="GET" class="mb-6">
      <div class="relative max-w-sm">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input type="text" name="q" value="<%= typeof search !== 'undefined' ? search : '' %>"
          placeholder="Buscar película..."
          class="w-full bg-zinc-800 border border-zinc-700 rounded-lg pl-9 pr-4 py-2 text-sm text-white focus:outline-none focus:border-blue-500 transition placeholder-zinc-600 shadow-inner" />
      </div>
    </form>

    <% if (!movies || movies.length === 0) { %>
    <div class="rounded-xl border border-dashed border-zinc-800 py-16 text-center">
      <p class="text-zinc-500 text-sm italic">Sin películas aún. Empezá importando una desde TMDB.</p>
    </div>
    <% } else { %>
    <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 overflow-hidden shadow-2xl">
      <table class="w-full text-sm text-left border-collapse">
        <thead class="bg-zinc-900 text-zinc-500 uppercase text-[10px] tracking-widest border-b border-zinc-800">
          <tr>
            <th class="px-4 py-4 font-semibold">Poster</th>
            <th class="px-4 py-4 font-semibold">Título</th>
            <th class="px-4 py-4 font-semibold hidden md:table-cell text-center">Año</th>
            <th class="px-4 py-4 font-semibold hidden md:table-cell text-center">Links</th>
            <th class="px-4 py-4 font-semibold hidden md:table-cell text-center">Vistas</th>
            <th class="px-4 py-4 font-semibold hidden md:table-cell">Estado</th>
            <th class="px-4 py-4"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-800/50">
          <% movies.forEach(function(movie) { %>
          <tr class="hover:bg-zinc-800/30 transition-colors group">
            <td class="px-4 py-3">
              <% if (movie.posterPath) { %>
              <img src="<%= movie.posterPath.startsWith('http') ? movie.posterPath : 'https://image.tmdb.org/t/p/w200' + movie.posterPath %>" 
                   alt="" class="w-10 h-14 object-cover rounded shadow-md group-hover:scale-105 transition-transform" loading="lazy" />
              <% } else { %>
              <div class="w-10 h-14 rounded bg-zinc-800 flex items-center justify-center text-zinc-600">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14"/></svg>
              </div>
              <% } %>
            </td>
            <td class="px-4 py-3">
              <p class="font-bold text-zinc-100 group-hover:text-blue-400 transition-colors"><%= movie.title %></p>
              <p class="text-[10px] text-zinc-500 mt-1 font-mono uppercase tracking-tighter">TMDB: <%= movie.tmdbId %></p>
            </td>
            <td class="px-4 py-3 text-zinc-400 hidden md:table-cell text-center font-mono">
              <%= (movie.releaseDate || '').slice(0,4) || '—' %>
            </td>
            <td class="px-4 py-3 hidden md:table-cell text-center">
              <span class="inline-flex items-center justify-center min-w-[24px] h-6 px-1.5 rounded-full text-[10px] font-bold border <%= movie.links.length > 0 ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' : 'bg-zinc-800 text-zinc-600 border-zinc-700/50' %>">
                <%= movie.links.length %>
              </span>
            </td>
            <td class="px-4 py-3 text-zinc-500 hidden md:table-cell text-center font-mono"><%= movie.viewCount || 0 %></td>
            <td class="px-4 py-3 hidden md:table-cell">
              <span class="inline-flex items-center gap-1.5 text-[10px] px-2.5 py-1 rounded-full font-bold uppercase tracking-wide <%= movie.active !== false ? 'bg-emerald-500/10 text-emerald-500 border border-emerald-500/20' : 'bg-zinc-800 text-zinc-500 border border-zinc-700' %>">
                <span class="w-1 h-1 rounded-full <%= movie.active !== false ? 'bg-emerald-500 animate-pulse' : 'bg-red-500' %>"></span>
                <%= movie.active !== false ? 'Activa' : 'Inactiva' %>
              </span>
            </td>
            <td class="px-4 py-3 text-right">
              <a href="/admin/movies/<%= movie._id %>/edit"
                class="inline-flex items-center p-2 bg-zinc-800 hover:bg-blue-600 hover:text-white text-zinc-400 rounded-lg transition-all shadow-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              </a>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>
</body>
</html>