# ─────────────────────────────────────────────
#  StreamX — Variables de entorno
#  Copia este archivo como .env y completalo
# ─────────────────────────────────────────────

# Servidor
PORT=3000
NODE_ENV=development

# Base de datos
# Local:
MONGODB_URI=mongodb://127.0.0.1:27017/streamx
# Nube (descomentar cuando migres):
# MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/streamx?retryWrites=true&w=majority

# Sesiones — CAMBIAR EN PRODUCCIÓN (mínimo 32 chars aleatorios)
SESSION_SECRET=streamx-dev-secret-cambiar-en-produccion-min32chars

# TMDB
TMDB_API_KEY=tu_api_key_de_themoviedb

# Admin inicial (solo se crea si la colección está vacía)
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=cambia_esta_contraseña_segura

# Rate Limiting (requests por ventana de 15 min)
RATE_LIMIT_MAX=200

# Cache TTL en segundos (para listas del catálogo)
CACHE_TTL=60

# ─── Vimeus ───────────────────────────────────────────────────────────────────
# VIEW_KEY: se usa en los iframes del player (frontend)
VIMEUS_VIEW_KEY=KXbbj5zd8t5Flden1YRzfeLDjsSiRE0YiOcNz5S3g-I
# API_KEY: se usa en el backend para import masivo
VIMEUS_API_KEY=ak_QoaqVJibTcS4NbuJffjjR5SQojtyBxIW
# Habilitar Vimeus como servidor automático (true/false)
VIMEUS_ENABLED=true
