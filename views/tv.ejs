    <!-- Category strip -->
    <div id="cat-strip">
      <div class="cat-pill all" onclick="filtrarCat('TODO',this)">▶ TODOS</div>
      <div class="cat-pill dep" onclick="filtrarCat('DEPORTES',this)">⚽ DEPORTES</div>
