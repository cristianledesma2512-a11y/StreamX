// ── Mundial ───────────────────────────────────────────────────────────────
db.ref("partidos").on("value", snap => {
  const data = snap.val(); if (!data) return;
  mundialData = Object.entries(data).map(([id,p]) => ({id,...p}));
  renderMundialGrupos();
  renderFixture("mun", mundialData, filtMundial);
  renderPosicionesTabla("mun-posiciones", mundialData);
});

function renderMundialGrupos() {
  const el = document.getElementById("mun-grupos"); el.innerHTML = "";
  const equipos = {};
  mundialData.forEach(p => {
    if (!p.grupo) return;
    [p.local, p.visitante].forEach((eq,i) => {
      if (!eq) return;
      if (!equipos[eq]) equipos[eq] = {nombre:eq,grupo:p.grupo,pj:0,pg:0,pe:0,pp:0,gf:0,gc:0,pts:0,bandera:i===0?p.bandera_local||"🏳":p.bandera_visitante||"🏳"};
    });
    if (p.estado==="FIN" && p.goles_local!=null && p.goles_visitante!=null) {
      const loc=equipos[p.local], vis=equipos[p.visitante]; if(!loc||!vis) return;
      loc.pj++;vis.pj++;loc.gf+=p.goles_local;loc.gc+=p.goles_visitante;vis.gf+=p.goles_visitante;vis.gc+=p.goles_local;
      if(p.goles_local>p.goles_visitante){loc.pg++;loc.pts+=3;vis.pp++;}
      else if(p.goles_local<p.goles_visitante){vis.pg++;vis.pts+=3;loc.pp++;}
      else{loc.pe++;vis.pe++;loc.pts++;vis.pts++;}
    }
  });
  const grupos = {};
  Object.values(equipos).forEach(eq => { if(!grupos[eq.grupo])grupos[eq.grupo]=[]; grupos[eq.grupo].push(eq); });
  Object.values(grupos).forEach(g => g.sort((a,b) => b.pts-a.pts||(b.gf-b.gc)-(a.gf-a.gc)));
  if (!Object.keys(grupos).length) { el.innerHTML='<p style="color:var(--muted);text-align:center;padding:30px;">⏳ Cargando grupos...</p>'; return; }
  el.style.padding = "8px 0";
  const grid = document.createElement("div"); grid.className = "grupos-grid";
  Object.entries(grupos).sort((a,b)=>a[0].localeCompare(b[0])).forEach(([grupo,eqs]) => {
    const card = document.createElement("div"); card.className = "grupo-card";
    card.innerHTML = `<div class="grupo-hdr"><div class="grupo-title">GRUPO ${grupo}</div><span style="font-size:10px;color:var(--muted)">🌍</span></div>`;
    const body = document.createElement("div"); body.className = "grupo-body";
    eqs.forEach((eq,i) => {
      const row = document.createElement("div"); row.className = "grupo-eq" + (i<2?" top":"");
      row.innerHTML = `<span>${eq.bandera}</span><span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${eq.nombre}</span><span style="color:var(--dor);font-weight:700">${eq.pts}</span>`;
      body.appendChild(row);
    });
    card.appendChild(body); grid.appendChild(card);
  });
  el.appendChild(grid);
}

function filtrarFixture(prefix, f, btn) {
  if (prefix === "mun") filtMundial = f;
  const zone = btn?.closest(".msec");
  zone?.querySelectorAll(".stab").forEach(b=>b.classList.remove("a"));
  if(btn) btn.classList.add("a");
  renderFixture(prefix, prefix==="mun"?mundialData:[], f);
}

function renderFixture(prefix, partidos, filtro) {
  const el = document.getElementById(prefix + "-fixture-list"); if(!el) return;
  let lista = [...partidos];
  const hoy = new Date().toISOString().slice(0,10);
  if (filtro==="ARG") lista = lista.filter(p=>p.local==="Argentina"||p.visitante==="Argentina");
  else if (filtro==="live") lista = lista.filter(p=>p.estado==="LIVE");
  else if (filtro==="hoy") lista = lista.filter(p=>p.fecha?.startsWith(hoy));
  lista.sort((a,b)=>(a.fecha||"").localeCompare(b.fecha||""));
  if (!lista.length) { el.innerHTML='<p style="color:var(--muted);text-align:center;padding:30px;">No hay partidos para mostrar</p>'; return; }
  const porFecha = {};
  lista.forEach(p => {
    const f = p.fecha ? new Date(p.fecha).toLocaleDateString("es-AR",{weekday:"short",day:"numeric",month:"short"}) : "Sin fecha";
    if(!porFecha[f])porFecha[f]=[];
    porFecha[f].push(p);
  });
  el.innerHTML = Object.entries(porFecha).map(([fecha,ps]) => `
    <div class="fecha-sep">📅 ${fecha}</div>
    ${ps.map(p => {
      const live=p.estado==="LIVE",fin=p.estado==="FIN",nScore=p.goles_local==null||p.goles_visitante==null;
      return `<div class="partido-row ${live?"live":""}">
        <div><div class="p-hora">${p.hora||"--:--"}</div><div class="p-badge ${live?"live":fin?"fin":"pronto"}">${live?"LIVE":fin?"FIN":"PRÓX"}</div></div>
        <div class="p-teams">
          <div class="p-team"><span>${p.bandera_local||"🏳"}</span><span>${p.local||"?"}</span></div>
          <div class="p-score${nScore?" pend":""}">${nScore?"vs":`${p.goles_local}-${p.goles_visitante}`}</div>
          <div class="p-team r"><span>${p.visitante||"?"}</span><span>${p.bandera_visitante||"🏳"}</span></div>
        </div>
        <div class="p-grp">${p.grupo||""}</div>
      </div>`;
    }).join("")}`).join("");
}

function renderPosicionesTabla(elId, partidos) {
  const el = document.getElementById(elId); if(!el) return;
  const equipos={};
  partidos.forEach(p=>{
    [p.local,p.visitante].forEach((eq,i)=>{
      if(!eq) return;
      if(!equipos[eq])equipos[eq]={nombre:eq,pj:0,pg:0,pe:0,pp:0,gf:0,gc:0,pts:0,bandera:i===0?p.bandera_local||"🏳":p.bandera_visitante||"🏳",grupo:p.grupo||""};
    });
    if(p.estado==="FIN"&&p.goles_local!=null&&p.goles_visitante!=null){
      const loc=equipos[p.local],vis=equipos[p.visitante];if(!loc||!vis)return;
      loc.pj++;vis.pj++;loc.gf+=p.goles_local;loc.gc+=p.goles_visitante;vis.gf+=p.goles_visitante;vis.gc+=p.goles_local;
      if(p.goles_local>p.goles_visitante){loc.pg++;loc.pts+=3;vis.pp++;}
      else if(p.goles_local<p.goles_visitante){vis.pg++;vis.pts+=3;loc.pp++;}
      else{loc.pe++;vis.pe++;loc.pts++;vis.pts++;}
    }
  });
  const lista=Object.values(equipos).sort((a,b)=>b.pts-a.pts||(b.gf-b.gc)-(a.gf-a.gc));
  if(!lista.length){el.innerHTML='<p style="color:var(--muted);text-align:center;padding:30px;">⏳ Sin resultados aún</p>';return;}
  el.style.overflowX="auto";
  el.innerHTML=`<table style="width:100%;border-collapse:collapse;font-size:11px;margin-top:8px;">
    <thead><tr style="background:rgba(24,24,27,0.6);">
      <th style="padding:7px 8px;text-align:left;color:var(--muted);font-size:10px;">#</th>
      <th style="padding:7px 4px;text-align:left;color:var(--muted);font-size:10px;">Equipo</th>
      <th style="padding:7px 4px;text-align:center;color:var(--muted);font-size:10px;">PJ</th>
      <th style="padding:7px 4px;text-align:center;color:var(--muted);font-size:10px;">PG</th>
      <th style="padding:7px 4px;text-align:center;color:var(--muted);font-size:10px;">DG</th>
      <th style="padding:7px 8px;text-align:center;color:var(--muted);font-size:10px;">PTS</th>
    </tr></thead>
    <tbody>${lista.map((eq,i)=>`<tr style="border-bottom:1px solid rgba(255,255,255,.04);${i<16?"border-left:3px solid rgba(46,204,113,.4)":i>=lista.length-8?"border-left:3px solid rgba(231,76,60,.4)":""}">
      <td style="padding:7px 8px;color:var(--muted)">${i+1}</td>
      <td style="padding:7px 4px"><div style="display:flex;align-items:center;gap:5px;"><span>${eq.bandera}</span><span style="font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:90px">${eq.nombre}</span></div></td>
      <td style="padding:7px 4px;text-align:center">${eq.pj}</td>
      <td style="padding:7px 4px;text-align:center">${eq.pg}</td>
      <td style="padding:7px 4px;text-align:center">${eq.gf-eq.gc>0?"+":""}${eq.gf-eq.gc}</td>
      <td style="padding:7px 8px;text-align:center;font-weight:700;color:var(--dor)">${eq.pts}</td>
    </tr>`).join("")}</tbody>
  </table>`;
}

