<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>StreamX - TV en Vivo</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <style>
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: #09090b; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #27272a; border-radius: 10px; }
    body { background-color: #09090b; color: #f4f4f5; }
  </style>
</head>
<body class="h-screen overflow-hidden flex flex-col">

  <header class="h-16 border-b border-zinc-800 flex items-center justify-between px-6 bg-zinc-950/50 backdrop-blur-md z-50">
    <div class="flex items-center gap-4">
      <a href="/" class="text-blue-500 hover:text-blue-400 transition"><i class="fas fa-arrow-left"></i></a>
      <h1 class="font-bold tracking-tighter text-xl">STREAM<span class="text-blue-600">X</span></h1>
    </div>
    <form action="/tv" method="GET" class="flex-1 max-w-md mx-6">
      <div class="relative">
        <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-zinc-600 text-xs"></i>
        <input type="text" name="q" value="<%= searchQuery %>" placeholder="Buscar canal..." 
               class="w-full bg-zinc-900/50 border border-zinc-800 rounded-full py-1.5 pl-9 pr-4 text-sm focus:outline-none focus:border-blue-500 transition">
      </div>
    </form>
    <div class="hidden md:block text-[10px] font-black text-zinc-700 tracking-[0.3em]">TECNOCON</div>
  </header>

  <div class="flex-1 flex overflow-hidden">
    <main class="flex-1 overflow-y-auto p-4 md:p-8 custom-scrollbar">
      
      <div id="player-container" class="relative aspect-video max-w-5xl mx-auto bg-black rounded-3xl overflow-hidden border border-zinc-800 shadow-2xl mb-10 group">
        <video id="video-player" class="w-full h-full" controls playsinline></video>
        <div id="player-loader" class="absolute inset-0 flex items-center justify-center bg-zinc-950 hidden">
          <div class="w-12 h-12 border-4 border-zinc-800 border-t-blue-600 rounded-full animate-spin"></div>
        </div>
        <div id="player-placeholder" class="absolute inset-0 flex flex-col items-center justify-center bg-zinc-900">
          <div class="w-20 h-20 bg-blue-600/10 rounded-full flex items-center justify-center mb-4">
            <i class="fas fa-play text-blue-600 text-2xl ml-1"></i>
          </div>
          <p class="text-zinc-500 font-medium text-sm">Selecciona una señal para comenzar</p>
        </div>
      </div>

      <div class="flex gap-2 mb-8 overflow-x-auto pb-2 no-scrollbar">
        <a href="/tv" class="px-4 py-1.5 rounded-full text-xs font-bold transition <%= !activeType ? 'bg-blue-600 text-white' : 'bg-zinc-900 text-zinc-500 hover:bg-zinc-800' %>">TODOS</a>
        <% const cats = ['General', 'Noticias', 'Deportes', 'Infantil', 'Cine']; %>
        <% cats.forEach(c => { %>
          <a href="/tv?type=<%= c %>" class="px-4 py-1.5 rounded-full text-xs font-bold transition <%= activeType === c ? 'bg-blue-600 text-white' : 'bg-zinc-900 text-zinc-500 hover:bg-zinc-800' %>"><%= c.toUpperCase() %></a>
        <% }) %>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-5">
        <% channels.forEach(channel => { %>
          <button onclick="playChannel('<%= channel.url %>', '<%= channel.name %>')" 
                  class="group flex flex-col items-center p-5 bg-zinc-900/30 border border-zinc-800/50 rounded-3xl hover:border-blue-600/50 hover:bg-zinc-900 transition-all">
            <div class="w-full aspect-square bg-white/5 rounded-2xl p-4 mb-4 flex items-center justify-center group-hover:scale-105 transition-transform duration-500">
              <img src="<%= channel.logo %>" alt="<%= channel.name %>" class="max-w-full max-h-full object-contain filter drop-shadow-2xl">
            </div>
            <span class="text-[11px] font-black uppercase tracking-wider text-zinc-500 group-hover:text-white truncate w-full"><%= channel.name %></span>
          </button>
        <% }) %>
      </div>

    </main>
  </div>

  <script>
    let hls = null;
    function playChannel(url, name) {
      const v = document.getElementById('video-player');
      const l = document.getElementById('player-loader');
      const p = document.getElementById('player-placeholder');

      if(hls) hls.destroy();
      p.style.display = 'none';
      l.classList.remove('hidden');

      if(url.includes('.m3u8')) {
        if(Hls.isSupported()) {
          hls = new Hls({ capLevelToPlayerSize: true });
          hls.loadSource(url);
          hls.attachMedia(v);
          hls.on(Hls.Events.MANIFEST_PARSED, () => { l.classList.add('hidden'); v.play(); });
        } else if(v.canPlayType('application/vnd.apple.mpegurl')) {
          v.src = url;
          v.onloadedmetadata = () => { l.classList.add('hidden'); v.play(); };
        }
      } else {
        v.src = url;
        v.onloadeddata = () => { l.classList.add('hidden'); v.play(); };
      }
      
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  </script>
</body>
</html>