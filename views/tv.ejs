    <div class="bl" id="bnav-lbl-1">Buscar</div>
  </div>
  <div class="bi" onclick="cambiarTab('tv',null);filtrarCat('FAV',null);setNavActive(2)">
    <svg viewBox="0 0 24 24" fill="none" stroke="#71717a" stroke-width="2" id="bnav-icon-2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
    <div class="bl" id="bnav-lbl-2">Favoritos</div>
  </div>
  <div class="bi" onclick="abrirFiltrosPais()">
    <svg viewBox="0 0 24 24" fill="none" stroke="#71717a" stroke-width="2" id="bnav-icon-3"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
    <div class="bl" id="bnav-lbl-3">Guía</div>
  </div>
