<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title><%= appName %> - TV en Vivo</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <style>
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: #18181b; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #3f3f46; border-radius: 10px; }
    body { background-color: #09090b; }
  </style>
</head>
<body class="text-zinc-100 font-sans overflow-hidden">

<div class="flex h-screen">
  <aside id="sidebar" class="fixed inset-y-0 left-0 z-50 w-64 bg-zinc-900 border-r border-zinc-800 transition-transform duration-300 -translate-x-full lg:translate-x-0 lg:static lg:inset-0">
    <div class="flex flex-col h-full p-6">
      <div class="flex items-center gap-3 mb-10">
        <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center"><i class="fas fa-play text-xs"></i></div>
        <span class="text-xl font-bold tracking-tighter">StreamX</span>
      </div>

      <nav class="space-y-6">
        <div>
          <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-4">Menú</p>
          <a href="/" class="flex items-center gap-3 text-zinc-400 hover:text-white py-2 transition"><i class="fas fa-home"></i> Inicio</a>
          <a href="/tv" class="flex items-center gap-3 text-blue-500 py-2 transition"><i class="fas fa-tv"></i> TV en Vivo</a>
        </div>
        <div>
          <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-4">Categorías</p>
          <div class="flex flex-col gap-2">
            <a href="/tv" class="text-sm <%= !activeType ? 'text-white' : 'text-zinc-400' %>">Todos</a>
            <% ['General', 'Noticias', 'Deportes', 'Infantil'].forEach(cat => { %>
              <a href="/tv?type=<%= cat %>" class="text-sm <%= activeType === cat ? 'text-white' : 'text-zinc-400' %>"><%= cat %></a>
            <% }) %>
          </div>
        </div>
      </nav>
    </div>
  </aside>

  <div id="overlay" onclick="closeSidebar()" class="fixed inset-0 bg-black/60 z-40 hidden lg:hidden"></div>

  <div class="flex-1 flex flex-col min-w-0">
    <header class="h-16 flex items-center justify-between px-6 border-b border-zinc-800/50">
      <button onclick="openSidebar()" class="lg:hidden p-2 text-zinc-400"><i class="fas fa-bars"></i></button>
      <form action="/tv" method="GET" class="flex-1 max-w-md mx-4">
        <input type="text" name="q" placeholder="Buscar canal..." value="<%= searchQuery %>" class="w-full bg-zinc-900 border border-zinc-800 rounded-xl px-4 py-1.5 text-sm focus:outline-none focus:border-blue-500">
      </form>
    </header>

    <main class="flex-1 overflow-y-auto p-6 custom-scrollbar">
      <div id="player-container" class="relative aspect-video bg-black rounded-2xl overflow-hidden border border-zinc-800 mb-8 shadow-2xl">
        <video id="video-player" class="w-full h-full" controls playsinline></video>
        <div id="player-loader" class="absolute inset-0 flex items-center justify-center bg-zinc-950 hidden">
            <div class="w-10 h-10 border-4 border-zinc-800 border-t-blue-500 rounded-full animate-spin"></div>
        </div>
        <div id="player-placeholder" class="absolute inset-0 flex flex-col items-center justify-center bg-zinc-900/50 backdrop-blur-sm">
            <i class="fas fa-play-circle text-6xl text-blue-600 mb-4 opacity-50"></i>
            <p class="text-zinc-400 font-medium">Selecciona un canal para reproducir</p>
        </div>
      </div>

      <h2 id="canal-nombre" class="text-2xl font-bold mb-6 italic text-blue-500 uppercase tracking-tighter">Canales Disponibles</h2>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
        <% channels.forEach(channel => { %>
          <button onclick="playChannel('<%= channel.url %>', '<%= channel.name %>')" class="group p-4 bg-zinc-900/50 border border-zinc-800 rounded-2xl hover:border-blue-600 transition">
            <div class="aspect-square mb-3 bg-zinc-800 rounded-xl flex items-center justify-center p-4">
                <img src="<%= channel.logo %>" class="max-w-full max-h-full object-contain group-hover:scale-110 transition shadow-lg">
            </div>
            <p class="text-xs font-bold text-zinc-400 group-hover:text-white truncate"><%= channel.name %></p>
          </button>
        <% }) %>
      </div>
    </main>
  </div>
</div>

<script>
let hls = null;
function playChannel(url, name) {
    const v = document.getElementById('video-player');
    const l = document.getElementById('player-loader');
    const p = document.getElementById('player-placeholder');
    document.getElementById('canal-nombre').innerText = name;

    if(hls) hls.destroy();
    p.style.display = 'none';
    l.classList.remove('hidden');

    if(url.includes('.m3u8')) {
        if(Hls.isSupported()) {
            hls = new Hls();
            hls.loadSource(url);
            hls.attachMedia(v);
            hls.on(Hls.Events.MANIFEST_PARSED, () => { l.classList.add('hidden'); v.play(); });
        } else if(v.canPlayType('application/vnd.apple.mpegurl')) {
            v.src = url;
            v.onloadedmetadata = () => { l.classList.add('hidden'); v.play(); };
        }
    } else {
        v.src = url;
        v.onloadeddata = () => { l.classList.add('hidden'); v.play(); };
    }
}

function openSidebar() { document.getElementById('sidebar').classList.remove('-translate-x-full'); document.getElementById('overlay').classList.remove('hidden'); }
function closeSidebar() { document.getElementById('sidebar').classList.add('-translate-x-full'); document.getElementById('overlay').classList.add('hidden'); }
</script>
</body>
</html>