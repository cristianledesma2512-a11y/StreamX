<!DOCTYPE html>
<html lang="es" class="dark">
<head><%- include('../partials/head', { title: 'Administradores — StreamX Admin' }) %></head>
<body class="bg-zinc-950 text-zinc-100 min-h-screen flex antialiased">
<%- include('partials/nav') %>

<div class="flex-1 overflow-y-auto">
  <div class="max-w-3xl mx-auto px-6 py-8">

    <h1 class="text-xl font-bold text-white mb-6">Administradores</h1>

    <% if (typeof error !== 'undefined' && error) { %>
    <div class="mb-4 rounded-lg bg-red-950/50 border border-red-800 px-4 py-3 text-sm text-red-300"><%= error %></div>
    <% } %>
    <% if (typeof msg !== 'undefined' && msg) { %>
    <div class="mb-4 rounded-lg bg-green-950/50 border border-green-800 px-4 py-3 text-sm text-green-300"><%= msg %></div>
    <% } %>

    <!-- Crear admin -->
    <div class="rounded-xl border border-zinc-800 bg-zinc-900/60 p-5 mb-6">
      <h2 class="text-sm font-semibold text-white mb-4">Crear nuevo administrador</h2>
      <form method="POST" action="/admin/admins" class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <div>
          <label class="block text-xs text-zinc-400 mb-1">Usuario</label>
          <input type="text" name="username" required placeholder="usuario"
            class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-violet-500 transition placeholder-zinc-600" />
        </div>
        <div>
          <label class="block text-xs text-zinc-400 mb-1">Contraseña</label>
          <input type="password" name="password" required placeholder="••••••••"
            class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-violet-500 transition" />
        </div>
        <div>
          <label class="block text-xs text-zinc-400 mb-1">Rol</label>
          <select name="role" class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-violet-500 transition">
            <option value="admin">Admin</option>
            <option value="super">Super</option>
          </select>
        </div>
        <div class="sm:col-span-3">
          <button type="submit" class="bg-violet-600 hover:bg-violet-700 text-white text-sm font-semibold px-5 py-2 rounded-lg transition">
            Crear usuario
          </button>
        </div>
      </form>
    </div>

    <!-- Lista admins -->
    <div class="rounded-xl border border-zinc-800 overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-zinc-900 border-b border-zinc-800">
          <tr>
            <th class="text-left px-4 py-3 text-xs text-zinc-500 font-medium">Usuario</th>
            <th class="text-left px-4 py-3 text-xs text-zinc-500 font-medium">Rol</th>
            <th class="text-left px-4 py-3 text-xs text-zinc-500 font-medium hidden md:table-cell">Último login</th>
            <th class="text-left px-4 py-3 text-xs text-zinc-500 font-medium hidden md:table-cell">Logins</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-800/50">
          <% admins.forEach(function(a) { %>
          <tr class="hover:bg-zinc-900/50 transition">
            <td class="px-4 py-3 font-medium text-white"><%= a.username %></td>
            <td class="px-4 py-3">
              <span class="text-xs px-2 py-0.5 rounded-full font-bold <%= a.role === 'super' ? 'bg-yellow-500/20 text-yellow-400' : 'bg-zinc-700 text-zinc-300' %>">
                <%= a.role %>
              </span>
            </td>
            <td class="px-4 py-3 text-zinc-500 text-xs hidden md:table-cell">
              <%= a.lastLoginAt ? new Date(a.lastLoginAt).toLocaleString('es-AR') : 'Nunca' %>
            </td>
            <td class="px-4 py-3 text-zinc-500 text-xs hidden md:table-cell"><%= a.loginCount || 0 %></td>
            <td class="px-4 py-3 text-right">
              <% if (a._id.toString() !== sessionAdminId) { %>
              <form method="POST" action="/admin/admins/<%= a._id %>/delete" onsubmit="return confirm('¿Eliminar usuario «<%= a.username %>»?')">
                <button type="submit" class="text-xs text-red-500 hover:text-red-400 border border-red-900/50 hover:border-red-700 px-2 py-1 rounded-lg transition">
                  Eliminar
                </button>
              </form>
              <% } else { %>
              <span class="text-xs text-zinc-600">(vos)</span>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

  </div>
</div>
</body>
</html>
