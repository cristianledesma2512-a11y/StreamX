<!DOCTYPE html>
<html lang="es" class="dark">
<head><%- include('partials/head', { title: 'TV en Vivo — StreamX' }) %>
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
</head>
<body class="bg-zinc-950 text-zinc-100 antialiased">

<div class="flex min-h-screen">

  <!-- NAV LATERAL -->
  <aside class="fixed top-0 left-0 z-40 h-full w-56 bg-zinc-900/95 border-r border-zinc-800/60 backdrop-blur-md flex flex-col -translate-x-full lg:translate-x-0 transition-transform duration-300" id="sidebar">
    <div class="px-5 py-6 border-b border-zinc-800/60">
      <a href="/" class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-violet-600 to-violet-800 flex items-center justify-center font-black text-white text-base shadow-lg">S</div>
        <div>
          <p class="font-bold text-white text-base leading-none">StreamX</p>
          <p class="text-[10px] text-zinc-500 mt-0.5">TECNOCOM</p>
        </div>
      </a>
    </div>

    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
      <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-zinc-400 hover:text-white hover:bg-zinc-800/60 transition-all">
        <svg style="width:18px;height:18px;flex-shrink:0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Inicio
      </a>
      <a href="/?type=movie" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-zinc-400 hover:text-white hover:bg-zinc-800/60 transition-all">
        <svg style="width:18px;height:18px;flex-shrink:0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/></svg>
        Películas
      </a>
      <a href="/?type=series" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-zinc-400 hover:text-white hover:bg-zinc-800/60 transition-all">
        <svg style="width:18px;height:18px;flex-shrink:0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        Series
      </a>
      <a href="/tv" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium bg-red-600/20 text-red-300 border border-red-500/20 transition-all">
        <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse shrink-0"></span>
        TV en Vivo
      </a>

      <!-- Categorías -->
      <div class="pt-4 pb-1">
        <p class="px-3 text-[10px] font-semibold text-zinc-600 uppercase tracking-widest">Categorías</p>
      </div>
      <a href="/tv" class="flex items-center gap-3 px-3 py-2 rounded-xl text-xs font-medium transition-all <%= !activeCategory ? 'bg-zinc-800 text-white' : 'text-zinc-500 hover:text-white hover:bg-zinc-800/60' %>">
        <span class="w-1.5 h-1.5 rounded-full bg-zinc-500 shrink-0"></span>
        Todos
      </a>
      <% categories.forEach(function(cat) { %>
      <a href="/tv?cat=<%= encodeURIComponent(cat) %>" class="flex items-center gap-3 px-3 py-2 rounded-xl text-xs font-medium transition-all <%= activeCategory === cat ? 'bg-zinc-800 text-white' : 'text-zinc-500 hover:text-white hover:bg-zinc-800/60' %>">
        <span class="w-1.5 h-1.5 rounded-full bg-zinc-600 shrink-0"></span>
        <%= cat %>
      </a>
      <% }); %>
    </nav>

    <div class="px-3 py-4 border-t border-zinc-800/60">
      <a href="/admin/login" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-xs text-zinc-500 hover:text-white hover:bg-zinc-800/60 transition-all">
        <svg style="width:16px;height:16px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Admin
      </a>
    </div>
  </aside>

  <!-- Overlay mobile -->
  <div id="overlay" class="fixed inset-0 bg-black/60 z-30 hidden lg:hidden" id="overlay"></div>

  <!-- CONTENIDO PRINCIPAL -->
  <div class="flex-1 lg:ml-56 min-w-0 flex flex-col">

    <!-- Top bar mobile -->
    <header class="lg:hidden sticky top-0 z-20 bg-zinc-950/90 backdrop-blur border-b border-zinc-800/60 px-4 py-3 flex items-center gap-3">
      <button id="sidebar-btn" class="text-zinc-400 hover:text-white transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <span class="font-bold text-white text-sm flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
        TV en Vivo
      </span>
    </header>

    <!-- PLAYER -->
    <div class="bg-black w-full" style="min-height: 0">
      <div id="player-container" class="relative w-full bg-zinc-900" style="padding-top: 42%">
        <!-- Placeholder inicial -->
        <div id="player-placeholder" class="absolute inset-0 flex flex-col items-center justify-center gap-3">
          <div class="w-16 h-16 rounded-full bg-zinc-800 flex items-center justify-center">
            <svg class="w-8 h-8 text-zinc-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
          </div>
          <p class="text-zinc-500 text-sm">Seleccioná un canal para comenzar</p>
        </div>

        <!-- Video HLS -->
        <video id="hls-player"
          class="absolute inset-0 w-full h-full object-contain hidden"
          controls autoplay playsinline>
        </video>

        <!-- Badge EN VIVO -->
        <div id="live-badge" class="hidden absolute top-3 left-3 flex items-center gap-1.5 bg-red-600 text-white text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full shadow">
          <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
          En Vivo
        </div>

        <!-- Info del canal activo -->
        <div id="channel-info" class="hidden absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent px-4 py-3">
          <p id="channel-name" class="text-white font-bold text-sm"></p>
          <p id="channel-cat" class="text-zinc-400 text-xs"></p>
        </div>

        <!-- Loading spinner -->
        <div id="player-loading" class="hidden absolute inset-0 bg-black/70 flex items-center justify-center">
          <div class="w-10 h-10 border-3 border-zinc-600 border-t-violet-500 rounded-full" style="border-width:3px;animation:spin .8s linear infinite"></div>
        </div>

        <!-- Error -->
        <div id="player-error" class="hidden absolute inset-0 bg-black/90 flex flex-col items-center justify-center gap-3 text-center px-6">
          <svg class="w-10 h-10 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <p class="text-zinc-300 text-sm">Canal no disponible en este momento</p>
          <button id="retry-btn" class="bg-violet-600 hover:bg-violet-700 text-white text-xs font-semibold px-4 py-2 rounded-lg transition">
            Reintentar
          </button>
        </div>
      </div>
    </div>

    <!-- GRID DE CANALES -->
    <div class="flex-1 px-4 lg:px-6 py-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-bold text-white flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
          Canales disponibles
          <span class="text-zinc-500 font-normal">(<%= channels.length %>)</span>
        </h2>
      </div>

      <div class="grid grid-cols-3 gap-2.5 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-5 xl:grid-cols-7" id="channels-grid">
        <% channels.forEach(function(ch) { %>
        <button type="button"
          data-url="<%= ch.url %>"
          data-name="<%= ch.name %>"
          data-category="<%= ch.category %>"
          class="channel-card group flex flex-col items-center gap-2 p-3 rounded-xl border border-zinc-800/60 bg-zinc-900/40 hover:border-red-500/50 hover:bg-zinc-800/60 transition-all cursor-pointer text-center">

          <!-- Logo -->
          <div class="w-12 h-12 rounded-xl bg-zinc-800 flex items-center justify-center overflow-hidden">
            <img src="<%= ch.logo %>" alt="<%= ch.name %>"
              class="w-full h-full object-contain p-1"
              class="channel-logo"
              loading="lazy" />
          </div>

          <!-- Nombre -->
          <p class="text-[10px] font-semibold text-zinc-300 group-hover:text-white leading-tight line-clamp-2 transition-colors">
            <%= ch.name %>
          </p>

          <!-- Badge idioma -->
          <span class="text-[8px] px-1.5 py-0.5 rounded-full font-bold
            <%= ch.language === 'Español' ? 'bg-yellow-500/20 text-yellow-400' : 'bg-zinc-700 text-zinc-500' %>">
            <%= ch.language %>
          </span>
        </button>
        <% }); %>
      </div>
    </div>

    <footer class="px-6 pb-4 text-xs text-zinc-700 text-center">
      StreamX &copy; <%= new Date().getFullYear() %> — TECNOCOM · Solo canales públicos y legales
    </footer>
  </div>
</div>

<style>
@keyframes spin { to { transform: rotate(360deg); } }
.channel-card.active { border-color: rgb(239 68 68 / 0.7); background: rgb(239 68 68 / 0.1); }
.channel-card.active p { color: white; }
</style>

<script>
var hls = null;
var currentUrl = null;
var currentName = null;
var currentCat = null;

// Eventos en channel cards — sin onclick inline
document.addEventListener('DOMContentLoaded', function() {
  // Canal cards
  document.querySelectorAll('.channel-card').forEach(function(card) {
    card.addEventListener('click', function() {
      var url      = card.dataset.url;
      var name     = card.dataset.name;
      var category = card.dataset.category;
      playChannel(url, name, category);
    });
  });

  // Botón retry
  var retryBtn = document.getElementById('retry-btn');
  if (retryBtn) retryBtn.addEventListener('click', retryChannel);

  // Logos con error
  document.querySelectorAll('.channel-logo').forEach(function(img) {
    img.addEventListener('error', function() {
      img.style.display = 'none';
    });
  });

  // Botón hamburguesa
  var sidebarBtn = document.getElementById('sidebar-btn');
  if (sidebarBtn) sidebarBtn.addEventListener('click', openSidebar);

  // Overlay cierra sidebar en mobile
  var overlay = document.getElementById('overlay');
  if (overlay) overlay.addEventListener('click', closeSidebar);

  // ESC cierra sidebar
  
});

function playChannel(url, name, category) {
  document.querySelectorAll('.channel-card').forEach(function(c) { c.classList.remove('active'); });
  document.querySelectorAll('.channel-card').forEach(function(c) {
    if (c.dataset.url === url) c.classList.add('active');
  });
  document.getElementById('player-container').scrollIntoView({ behavior: 'smooth', block: 'start' });
  currentUrl  = url;
  currentName = name;
  currentCat  = category;
  loadChannel(url, name, category);
}

function loadChannel(url, name, category) {
  var video    = document.getElementById('hls-player');
  var loading  = document.getElementById('player-loading');
  var error    = document.getElementById('player-error');
  var placeholder = document.getElementById('player-placeholder');
  var badge    = document.getElementById('live-badge');
  var info     = document.getElementById('channel-info');

  // Resetear estado
  placeholder.classList.add('hidden');
  error.classList.add('hidden');
  loading.classList.remove('hidden');
  video.classList.remove('hidden');
  badge.classList.remove('hidden');
  info.classList.remove('hidden');

  document.getElementById('channel-name').textContent = name;
  document.getElementById('channel-cat').textContent  = category;

  // Destruir HLS anterior
  if (hls) { hls.destroy(); hls = null; }
  video.src = '';

  if (Hls.isSupported()) {
    hls = new Hls({ enableWorker: true, lowLatencyMode: true });
    hls.loadSource(url);
    hls.attachMedia(video);

    hls.on(Hls.Events.MANIFEST_PARSED, function() {
      loading.classList.add('hidden');
      video.play().catch(function() {});
    });

    hls.on(Hls.Events.ERROR, function(event, data) {
      if (data.fatal) {
        loading.classList.add('hidden');
        video.classList.add('hidden');
        error.classList.remove('hidden');
        badge.classList.add('hidden');
      }
    });
  } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
    // Safari nativo
    video.src = url;
    video.addEventListener('loadedmetadata', function() {
      loading.classList.add('hidden');
      video.play();
    });
  } else {
    loading.classList.add('hidden');
    error.classList.remove('hidden');
  }
}

function retryChannel() {
  if (currentUrl) loadChannel(currentUrl, currentName || '', currentCat || '');
}

function openSidebar() {
  document.getElementById('sidebar').classList.remove('-translate-x-full');
  document.getElementById('overlay').classList.remove('hidden');
}
function closeSidebar() {
  document.getElementById('sidebar').classList.add('-translate-x-full');
  document.getElementById('overlay').classList.add('hidden');
}
document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeSidebar(); });
</script>
</body>
</html>

