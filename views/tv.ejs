      body.appendChild(row);
    });
    card.appendChild(body);grid.appendChild(card);
  });
  el.appendChild(grid);
}

function renderPartidosConmebol(elId, partidos) {
  const el=document.getElementById(elId);if(!el)return;
  const lista=Object.values(partidos||{}).sort((a,b)=>(a.fecha||"").localeCompare(b.fecha||""));
  if(!lista.length){el.innerHTML='<p style="color:var(--muted);text-align:center;padding:30px;">📅 Partidos próximamente</p>';return;}
  renderFixture("_tmp", lista, "todos");
}

function renderPosicionesConmebol(elId, partidos) {
