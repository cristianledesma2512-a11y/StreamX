<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>TV en Vivo — StreamX</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #09090b; color: #fafafa; }
        .channel-card:hover img { transform: scale(1.1); }
        .active-category { background: #7c3aed; color: white; border-color: #7c3aed; }
        /* Ocultar scrollbar */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="min-h-screen pb-20">

    <header class="sticky top-0 z-50 bg-zinc-950/80 backdrop-blur-md border-b border-zinc-800 px-4 py-4">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <a href="/" class="text-2xl font-black italic tracking-tighter">STREAM<span class="text-violet-500">X</span></a>
                <span class="bg-violet-500/10 text-violet-500 text-[10px] font-bold px-2 py-0.5 rounded-full border border-violet-500/20 uppercase tracking-widest">Live TV</span>
            </div>
            
            <form action="/tv" method="GET" class="relative flex-1 max-w-md">
                <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-zinc-500 text-sm"></i>
                <input type="text" name="q" value="<%= searchQuery %>" placeholder="Buscar canales..." 
                    class="w-full bg-zinc-900 border border-zinc-800 rounded-2xl py-2.5 pl-11 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/50 transition-all">
            </form>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 pt-8">
        
        <div id="player-container" class="relative aspect-video max-w-5xl mx-auto rounded-[2rem] overflow-hidden border border-zinc-800 shadow-2xl bg-black mb-10">
            <video id="video-player" class="w-full h-full" controls playsinline style="display:none;"></video>
            
            <iframe id="iframe-player" class="w-full h-full" frameborder="0" allowfullscreen allow="autoplay; encrypted-media" style="display:none;"></iframe>
            
            <div id="player-loader" class="absolute inset-0 flex items-center justify-center bg-zinc-950 hidden z-20">
                <div class="w-12 h-12 border-4 border-zinc-800 border-t-violet-600 rounded-full animate-spin"></div>
            </div>

            <div id="player-placeholder" class="absolute inset-0 flex flex-col items-center justify-center bg-zinc-950 z-10 text-center px-6">
                <div class="w-20 h-20 bg-violet-600/10 rounded-full flex items-center justify-center mb-4 border border-violet-500/20">
                    <i class="fas fa-play text-violet-500 text-3xl"></i>
                </div>
                <h2 class="text-xl font-bold">Listo para transmitir</h2>
                <p class="text-zinc-500 text-sm mt-1">Selecciona un canal de la lista inferior</p>
            </div>
        </div>

        <div class="flex gap-2 overflow-x-auto no-scrollbar mb-8 pb-2">
            <a href="/tv" class="px-5 py-2 rounded-full border border-zinc-800 text-sm font-semibold whitespace-nowrap transition-all <%= !activeType ? 'active-category' : 'bg-zinc-900 text-zinc-400 hover:bg-zinc-800' %>">Todos</a>
            <% const categories = [...new Set(channels.map(c => c.category))]; %>
            <% categories.forEach(cat => { %>
                <a href="/tv?type=<%= cat %>" class="px-5 py-2 rounded-full border border-zinc-800 text-sm font-semibold whitespace-nowrap transition-all <%= activeType === cat ? 'active-category' : 'bg-zinc-900 text-zinc-400 hover:bg-zinc-800' %>"><%= cat %></a>
            <% }); %>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
            <% channels.forEach(channel => { %>
                <div onclick="playChannel('<%= channel.url %>', '<%= channel.name %>')" 
                    class="channel-card group cursor-pointer bg-zinc-900/50 border border-zinc-800 rounded-3xl p-4 transition-all hover:bg-zinc-800 hover:border-violet-500/50">
                    <div class="aspect-square rounded-2xl overflow-hidden bg-black mb-4 border border-zinc-800 group-hover:border-violet-500/30 transition-all">
                        <img src="<%= channel.logo %>" alt="<%= channel.name %>" class="w-full h-full object-contain p-4 transition-transform duration-500">
                    </div>
                    <h3 class="text-center text-sm font-bold truncate group-hover:text-violet-400 transition-colors"><%= channel.name %></h3>
                    <p class="text-center text-[10px] text-zinc-500 uppercase tracking-widest mt-1"><%= channel.category %></p>
                </div>
            <% }); %>
        </div>

        <% if (channels.length === 0) { %>
            <div class="text-center py-20">
                <i class="fas fa-search text-4xl text-zinc-800 mb-4"></i>
                <p class="text-zinc-500 font-medium">No encontramos canales que coincidan.</p>
            </div>
        <% } %>
    </main>

    <script>
        let hls = null;

        function playChannel(url, name) {
            console.log("Sintonizando:", name);
            const video = document.getElementById('video-player');
            const iframe = document.getElementById('iframe-player');
            const placeholder = document.getElementById('player-placeholder');
            const loader = document.getElementById('player-loader');

            // 1. Preparar Interfaz
            placeholder.style.display = 'none';
            loader.classList.remove('hidden');
            
            // 2. Limpiar reproductores previos
            if(hls) { hls.destroy(); hls = null; }
            video.src = "";
            iframe.src = "";
            video.style.display = "none";
            iframe.style.display = "none";

            // 3. Lógica de Detección (M3U8 vs Embed)
            // Si el link tiene .m3u8 o .mp4 es video directo
            const isDirectVideo = url.includes('.m3u8') || url.includes('.mp4') || url.includes('.ts') || url.includes('akamaized');

            if (isDirectVideo) {
                video.style.display = "block";
                if (Hls.isSupported()) {
                    hls = new Hls({
                        enableWorker: true,
                        lowLatencyMode: true
                    });
                    hls.loadSource(url);
                    hls.attachMedia(video);
                    hls.on(Hls.Events.MANIFEST_PARSED, () => {
                        loader.classList.add('hidden');
                        video.play().catch(e => console.log("Auto-play blocked"));
                    });
                    hls.on(Hls.Events.ERROR, (event, data) => {
                        if (data.fatal) {
                            console.error("Error HLS Fatal, reintentando nativo...");
                            video.src = url;
                        }
                    });
                } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
                    // Para Safari/iOS
                    video.src = url;
                    video.onloadedmetadata = () => {
                        loader.classList.add('hidden');
                        video.play();
                    };
                }
            } else {
                // Si no es link directo, asumimos que es un EMBED (YouTube, StreamTP, etc)
                iframe.style.display = "block";
                iframe.src = url;
                iframe.onload = () => {
                    loader.classList.add('hidden');
                };
            }

            // Scroll suave al reproductor
            document.getElementById('player-container').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    </script>
</body>
</html>