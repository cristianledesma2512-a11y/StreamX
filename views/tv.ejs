    <svg viewBox="0 0 24 24" fill="none" stroke="#71717a" stroke-width="2" id="bnav-icon-4"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    <div class="bl" id="bnav-lbl-4">Chat</div>
  </div>
</div>

<div id="toast"></div>
<button id="btn-instalar">📲 Instalar App</button>
<div id="ios-banner">
  <button id="ios-close">✕</button>
  <p>Para instalar: tocá <strong>Compartir</strong> → <strong>Agregar a pantalla de inicio</strong></p>
</div>



</div>

<script>

// ── Firebase ──────────────────────────────────────────────────────────────
firebase.initializeApp({ databaseURL: "https://streamx-53ace-default-rtdb.firebaseio.com/" });
const db = firebase.database();

// ── Estado ────────────────────────────────────────────────────────────────
let miNick       = localStorage.getItem("mnv_nick") || "";
let todosCanales = [];
let favoritos    = JSON.parse(localStorage.getItem("mnv_favs") || "[]");
let historial    = JSON.parse(localStorage.getItem("mnv_hist") || "[]");
let hlsInstance  = null;
let canalActivo  = null;
let urlActual    = "";
let fbActual     = [];
let catActual    = "TODO";
let mundialData  = [];
let filtMundial  = "todos";
const LOGO_DEF   = "https://cdn-icons-png.flaticon.com/512/716/716429.png";

// ── Toast ─────────────────────────────────────────────────────────────────
function toast(msg, t=2800) {
  const el = document.getElementById("toast");
  el.textContent = msg; el.classList.add("show");
  setTimeout(() => el.classList.remove("show"), t);
}

// ── Modal apodo ───────────────────────────────────────────────────────────
if (miNick) {
  document.getElementById("modal-nick").style.display = "none";
  document.getElementById("user-badge").textContent = miNick.slice(0,2).toUpperCase();
}
// Detectar TV Box / Android TV
const esTVBox = /Android/i.test(navigator.userAgent) && window.innerWidth >= 900 && !('ontouchstart' in window);

if (esTVBox && !miNick) {
  // En TV Box asignar nick automático y saltear modal
  const autoNick = "Viewer" + Math.floor(Math.random()*9000+1000);
  localStorage.setItem("mnv_nick", autoNick); miNick = autoNick;
  document.getElementById("modal-nick").style.display = "none";
  document.getElementById("user-badge").textContent = "TV";
  registrarPresencia(autoNick);
} else {
  // Auto-skip si no escribe en 30 segundos
  let autoSkipTimer = setTimeout(() => {
    const input = document.getElementById("nick-in");
    if (input && !miNick) {
      const autoNick = "Invitado" + Math.floor(Math.random()*9000+1000);
      localStorage.setItem("mnv_nick", autoNick); miNick = autoNick;
      document.getElementById("modal-nick").style.display = "none";
      document.getElementById("user-badge").textContent = "IV";
      registrarPresencia(autoNick);
    }
  }, 30000);

  document.getElementById("nick-btn").onclick = () => {
    clearTimeout(autoSkipTimer);
    let n = document.getElementById("nick-in").value.trim();
    if (!n) n = "Invitado" + Math.floor(Math.random()*9000+1000);
    localStorage.setItem("mnv_nick", n); miNick = n;
    document.getElementById("modal-nick").style.display = "none";
    document.getElementById("user-badge").textContent = n.slice(0,2).toUpperCase();
    toast("¡Bienvenido " + n + "! ⚽");
    registrarPresencia(n);
  };
  document.getElementById("nick-in").addEventListener("keydown", e => { if(e.key==="Enter") document.getElementById("nick-btn").click(); });
}
document.getElementById("user-badge").onclick = () => { if(confirm("¿Cambiar apodo?")) { localStorage.removeItem("mnv_nick"); location.reload(); } };

// ── Tabs ──────────────────────────────────────────────────────────────────
function cambiarTab(tab, btn) {
  document.querySelectorAll(".section").forEach(s => s.classList.remove("a"));
  document.querySelectorAll(".ntab").forEach(b => b.classList.remove("a"));
  // Mapear tabs nuevas a sus IDs de sección
  const tabMap = { categorias: "sec-categorias", guia: "sec-guia" };
  const secId = tabMap[tab] ? tabMap[tab] : "sec-" + tab;
  const sec = document.getElementById(secId);
  if (sec) sec.classList.add("a");
  if (btn) btn.classList.add("a");
  else {
    const idx = {tv:0,mundial:1,conmebol:2,chat:3}[tab];
    if (idx !== undefined) document.querySelectorAll(".ntab")[idx]?.classList.add("a");
  }
  if (tab === "chat") {
    document.getElementById("main").style.overflow = "hidden";
    document.getElementById("sec-chat").style.height = "calc(100vh - 170px)";
  } else {
    document.getElementById("main").style.overflow = "auto";
  }
}

function cambiarSub(prefix, sec, btn) {
  const parent = btn?.closest(".msec-wrap") || document.getElementById("sec-" + (prefix==="mun"?"mundial":"conmebol"));
  if (!parent) return;
  const zone = prefix === "mun" ? parent : btn?.closest(".msec")?.parentElement || parent;
  zone.querySelectorAll(":scope > .msec").forEach(s => s.classList.remove("a"));
  zone.querySelectorAll(":scope > .sub-tabs .stab, :scope > div > .sub-tabs .stab").forEach(b => b.classList.remove("a"));
  const el = document.getElementById(prefix + "-" + sec);
  if (el) el.classList.add("a");
  if (btn) btn.classList.add("a");
}

function cambiarConmebol(torneo, btn) {
  document.querySelectorAll("#sec-conmebol .msec-wrap > .msec").forEach(s => s.classList.remove("a"));
  document.querySelectorAll("#sec-conmebol .msec-wrap > .sub-tabs .stab").forEach(b => b.classList.remove("a"));
  document.getElementById("con-" + torneo)?.classList.add("a");
  if (btn) btn.classList.add("a");
}

function setNavActive(idx) {
  for (let i=0; i<5; i++) {
    const lbl = document.getElementById("bnav-lbl-" + i);
    const ico = document.getElementById("bnav-icon-" + i);
    if (lbl) lbl.classList.toggle("a", i === idx);
    if (ico) ico.setAttribute("stroke", i === idx ? "#a78bfa" : "#71717a");
  }
}

// ── Search ────────────────────────────────────────────────────────────────
document.getElementById("btn-srch-toggle").onclick = abrirBusqueda;
function abrirBusqueda() {
  const bar = document.getElementById("srch-bar");
  bar.style.display = bar.style.display === "none" ? "block" : "none";
  if (bar.style.display === "block") {
    document.getElementById("srch-input").focus();
    setNavActive(1);
  }
}
document.getElementById("srch-input").addEventListener("input", function() {
  const q = this.value.trim().toLowerCase();
  if (!q) { renderTV(); return; }
  const res = todosCanales.filter(c => c.nombre.toLowerCase().includes(q));
  renderSearchResults(res);
});

function renderSearchResults(lista) {
  const body = document.getElementById("tv-body");
  body.innerHTML = "";
  if (!lista.length) { body.innerHTML = '<p style="color:var(--muted);text-align:center;padding:30px;">Sin resultados</p>'; return; }
  const wrap = document.createElement("div");
  wrap.id = "srch-results";
  lista.forEach(c => {
    const item = document.createElement("div");
    item.className = "srch-item";
    item.innerHTML = `<div class="srch-thumb"><img src="${c.logo||LOGO_DEF}" onerror="this.src='${LOGO_DEF}'" alt="${c.nombre}"></div><div class="srch-info"><div class="srch-name">${c.nombre}</div><div class="srch-cat">${c.categoria||""}</div></div><div class="srch-play"><div class="ptri"></div></div>`;
    item.onclick = () => reproducir(c.url, c.nombre, c.fallbacks||[]);
    wrap.appendChild(item);
  });
  body.appendChild(wrap);
}

// ── Player ────────────────────────────────────────────────────────────────
const videoEl   = document.getElementById("video-el");
const iframeEl  = document.getElementById("iframe-el");
const spinner   = document.getElementById("hero-spinner");
const playerErr = document.getElementById("hero-err");
const placeholder = document.getElementById("hero-placeholder");
const heroBadge = document.getElementById("hero-badge");
const heroInfo  = document.getElementById("hero-info");
const heroCanal = document.getElementById("hero-canal");
const heroSub   = document.getElementById("hero-sub");
const qualityEl = document.getElementById("hero-quality");

function mostrarSpinner(v) { spinner.style.display = v ? "flex" : "none"; }
function mostrarError(v)   { playerErr.style.display = v ? "flex" : "none"; }

function reproducir(url, nombre, fallbacks=[]) {
  if (!url) { toast("⚠️ Sin señal disponible"); return; }
  canalActivo = nombre; urlActual = url; fbActual = fallbacks;
  placeholder.style.display = "none";
  heroBadge.style.display = "block";
  heroInfo.style.display = "block";
  heroCanal.textContent = nombre;
  heroSub.textContent = "Cargando...";
  agregarHistorial(nombre, url, fallbacks);
  document.getElementById("player-hero").scrollIntoView({ behavior: "smooth", block: "start" });
  intentarPlay([url, ...fallbacks.filter(u => u !== url)], 0, nombre);
}

function intentarPlay(urls, idx, nombre) {
  if (idx >= urls.length) { mostrarSpinner(false); mostrarError(true); toast("❌ Sin señal para " + nombre); return; }
  const url = urls[idx];
  mostrarError(false); mostrarSpinner(true);
  qualityEl.innerHTML = ""; qualityEl.style.display = "none";
  heroSub.textContent = idx > 0 ? "Probando fuente " + (idx+1) + "..." : "En vivo";
  if (idx > 0) toast("🔄 Probando fuente " + (idx+1) + "...");

  if (url.includes("youtube") || url.includes("nocookie") || url.includes("embed") || url.includes(".php") || url.includes("bolaloca")) {
    videoEl.style.display = "none"; iframeEl.style.display = "block"; iframeEl.src = url;
    mostrarSpinner(false); heroSub.textContent = "En vivo"; return;
  }

  videoEl.style.display = "block"; iframeEl.style.display = "none"; iframeEl.src = "";
  if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }

  if (Hls.isSupported()) {
    const hls = new Hls({ enableWorker: true, lowLatencyMode: true, maxBufferLength: 20 });
    hlsInstance = hls; hls.loadSource(url); hls.attachMedia(videoEl);
    hls.on(Hls.Events.MANIFEST_PARSED, (e, data) => {
      mostrarSpinner(false); heroSub.textContent = "En vivo"; videoEl.play().catch(()=>{});
      if (data.levels && data.levels.length > 1) {
        qualityEl.style.display = "flex";
        const btnA = document.createElement("div"); btnA.className = "q-btn a"; btnA.textContent = "Auto";
        btnA.onclick = () => { hls.currentLevel = -1; qualityEl.querySelectorAll(".q-btn").forEach(b=>b.classList.remove("a")); btnA.classList.add("a"); };
        qualityEl.appendChild(btnA);
        data.levels.forEach((lv, i) => {
          const btn = document.createElement("div"); btn.className = "q-btn";
          btn.textContent = lv.height ? lv.height + "p" : "Nivel " + i;
          btn.onclick = () => { hls.currentLevel = i; qualityEl.querySelectorAll(".q-btn").forEach(b=>b.classList.remove("a")); btn.classList.add("a"); };
          qualityEl.appendChild(btn);
        });
      }
    });
    hls.on(Hls.Events.ERROR, (e, data) => { if(data.fatal) { hls.destroy(); hlsInstance = null; setTimeout(()=>intentarPlay(urls,idx+1,nombre),800); } });
    videoEl.addEventListener("waiting", () => mostrarSpinner(true), { once: false });
    videoEl.addEventListener("playing", () => mostrarSpinner(false), { once: false });
  } else if (videoEl.canPlayType("application/vnd.apple.mpegurl")) {
    videoEl.src = url;
    videoEl.addEventListener("loadedmetadata", () => { mostrarSpinner(false); videoEl.play().catch(()=>{}); }, { once: true });
    videoEl.addEventListener("error", () => { setTimeout(()=>intentarPlay(urls,idx+1,nombre),800); }, { once: true });
  } else { mostrarSpinner(false); mostrarError(true); }
}

document.getElementById("btn-retry").onclick = () => { if(urlActual && canalActivo) reproducir(urlActual, canalActivo, fbActual); };
document.getElementById("btn-fs").onclick = () => {
  const box = document.getElementById("player-hero");
  if (!document.fullscreenElement) box.requestFullscreen?.().catch(()=>{});
  else document.exitFullscreen?.();
};
document.getElementById("btn-rep-c").onclick = () => {
  if (!canalActivo) { toast("⚠️ Primero seleccioná un canal"); return; }
  db.ref("reportes").push({ canal: canalActivo, usuario: miNick || "anónimo", fecha: firebase.database.ServerValue.TIMESTAMP });
  toast("✅ Reporte enviado");
};

// ── Favoritos ────────────────────────────────────────────────────────────
function esFavorito(nombre) { return favoritos.includes(nombre); }
function toggleFav(nombre) {
  if (esFavorito(nombre)) { favoritos = favoritos.filter(f => f !== nombre); toast("⭐ Quitado de favoritos"); }
  else { favoritos.unshift(nombre); if(favoritos.length > 20) favoritos.pop(); toast("⭐ Agregado a favoritos"); }
  localStorage.setItem("mnv_favs", JSON.stringify(favoritos));
  renderTV();
}

// ── Historial ─────────────────────────────────────────────────────────────
function agregarHistorial(nombre, url, fallbacks) {
  historial = historial.filter(h => h.nombre !== nombre);
  historial.unshift({ nombre, url, fallbacks, ts: Date.now() });
  if (historial.length > 10) historial.pop();
  localStorage.setItem("mnv_hist", JSON.stringify(historial));
}

function tiempoRelativo(ts) {
  const m = Math.floor((Date.now() - ts) / 60000);
  if (m < 1) return "Hace un momento";
  if (m < 60) return "Hace " + m + " min";
  const h = Math.floor(m / 60);
  if (h < 24) return "Hace " + h + "h";
  return "Ayer";
}

// ── Canales desde Firebase ────────────────────────────────────────────────
db.ref("canales").on("value", snap => {
  const data = snap.val(); if (!data) return;
  const raw = data.canales ? data.canales : data;
  todosCanales = Object.keys(raw).map(id => ({ id, ...raw[id] }));
  renderTV();
});

// ── Filtrar por categoría ─────────────────────────────────────────────────
function filtrarCat(cat, btn) {
  catActual = cat;
  document.querySelectorAll(".cat-pill").forEach(p => {
    const cls = p.classList[1];
    const map = { all:"TODO", dep:"DEPORTES", not:"NOTICIAS", aire:"AIRE", mus:"MUSICA", inf:"INFANTIL", int:"INTERNACIONAL" };
    p.classList.toggle("active-pill", map[cls] === cat);
  });
  renderTV();
}

// ── Render TV ─────────────────────────────────────────────────────────────
// ── CATEGORÍAS ────────────────────────────────────────────────────────────
function renderCategorias() {
  const body = document.getElementById("cat-body");
  if (!body || !todosCanales.length) return;
  const cats = {};
  todosCanales.forEach(c => {
    const cat = (c.categoria || "Otros").toUpperCase();
    if (!cats[cat]) cats[cat] = [];
    cats[cat].push(c);
  });
  body.innerHTML = "";
  Object.keys(cats).sort().forEach(cat => {
    const canales = cats[cat];
    const sec = document.createElement("div");
    sec.style.cssText = "margin-bottom:20px;";
    const titulo = document.createElement("div");
    titulo.style.cssText = "font-size:12px;font-weight:700;color:var(--dor);text-transform:uppercase;letter-spacing:.8px;margin-bottom:10px;padding:0 4px;border-left:3px solid var(--dor);padding-left:10px;";
    titulo.textContent = cat;
    sec.appendChild(titulo);
    const grid = document.createElement("div");
    grid.style.cssText = "display:grid;grid-template-columns:repeat(auto-fill,minmax(70px,1fr));gap:8px;";
    canales.forEach(c => {
      const card = document.createElement("div");
      card.style.cssText = "background:var(--card);border-radius:10px;padding:10px 6px;display:flex;flex-direction:column;align-items:center;gap:6px;cursor:pointer;border:1px solid rgba(139,92,246,0.15);transition:all .2s;";
      card.innerHTML = `<img src="${c.logo||LOGO_DEF}" onerror="this.src='${LOGO_DEF}'" style="width:36px;height:36px;object-fit:contain;border-radius:6px;" loading="lazy"><span style="font-size:9px;color:var(--txt);text-align:center;line-height:1.2;font-weight:600;">${c.nombre}</span>`;
      card.onclick = () => { reproducir(c.url, c.nombre, c.fallbacks||[]); cambiarTab("tv", document.querySelector(".ntab")); };
      card.onmouseenter = () => card.style.borderColor = "rgba(139,92,246,0.5)";
      card.onmouseleave = () => card.style.borderColor = "rgba(139,92,246,0.15)";
      grid.appendChild(card);
    });
    sec.appendChild(grid);
    body.appendChild(sec);
  });
}

// ── GUÍA ──────────────────────────────────────────────────────────────────
function renderGuia() {
  const body = document.getElementById("guia-body");
  if (!body || !todosCanales.length) return;
  body.innerHTML = "";
  const titulo = document.createElement("div");
  titulo.style.cssText = "font-size:13px;font-weight:700;color:var(--txt);margin-bottom:12px;";
  titulo.textContent = "📺 Canales disponibles — " + todosCanales.length + " señales";
  body.appendChild(titulo);
  const tabla = document.createElement("div");
  tabla.style.cssText = "display:flex;flex-direction:column;gap:4px;";
  todosCanales.forEach((c, i) => {
    const row = document.createElement("div");
    const bg = i % 2 === 0 ? "var(--card)" : "var(--card2)";
    row.style.cssText = `display:flex;align-items:center;gap:10px;padding:8px 12px;background:${bg};border-radius:8px;cursor:pointer;transition:all .2s;`;
    row.innerHTML = `
      <span style="font-size:10px;color:var(--muted);width:24px;text-align:right;flex-shrink:0;">${i+1}</span>
      <img src="${c.logo||LOGO_DEF}" onerror="this.src='${LOGO_DEF}'" style="width:28px;height:28px;object-fit:contain;border-radius:5px;flex-shrink:0;" loading="lazy">
      <div style="flex:1;min-width:0;">
        <div style="font-size:12px;font-weight:700;color:var(--txt);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${c.nombre}</div>
        <div style="font-size:10px;color:var(--muted);">${(c.categoria||"").toUpperCase()} ${c.pais ? "· "+c.pais : ""}</div>
      </div>
      <div style="flex-shrink:0;">
        <div style="width:6px;height:6px;border-radius:50%;background:${c.url ? "#10b981" : "#ef4444"};"></div>
      </div>
    `;
    row.onclick = () => { reproducir(c.url, c.nombre, c.fallbacks||[]); cambiarTab("tv", document.querySelector(".ntab")); };
    row.onmouseenter = () => row.style.background = "rgba(139,92,246,0.1)";
    row.onmouseleave = () => row.style.background = bg;
    tabla.appendChild(row);
  });
  body.appendChild(tabla);
}

function renderTV() {
  const body = document.getElementById("tv-body");
  body.innerHTML = "";

  let lista = todosCanales;
  if (catActual !== "TODO") {
    if (catActual === "FAV") lista = todosCanales.filter(c => esFavorito(c.nombre));
    else lista = todosCanales.filter(c => (c.categoria||"").toUpperCase() === catActual);
  }

  if (catActual !== "TODO") {
    // Vista de grilla al filtrar por categoría
    renderGrillaCanales(body, lista, catActual);
    return;
  }

  // Vista principal — carruseles por sección

  // Favoritos
  const favsList = todosCanales.filter(c => esFavorito(c.nombre));
  if (favsList.length > 0) {
    const sec = crearSeccion("⭐ Mis favoritos", null, favsList.length, "FAV");
    const strip = document.createElement("div"); strip.className = "fav-strip";
    favsList.forEach(c => {
      const pill = document.createElement("div"); pill.className = "fav-pill" + (canalActivo===c.nombre?" a":"");
      pill.innerHTML = `<div class="fdot"></div><div class="fname">${c.nombre}</div>`;
      pill.onclick = () => reproducir(c.url, c.nombre, c.fallbacks||[]);
      strip.appendChild(pill);
    });
    const addPill = document.createElement("div"); addPill.className = "fav-pill add"; addPill.textContent = "+ Agregar";
    addPill.onclick = () => { filtrarCat("TODO", null); toast("Tocá ❤️ en cualquier canal para agregar"); };
    strip.appendChild(addPill);
    sec.appendChild(strip); body.appendChild(sec);
  }

  // Deportes — carrusel pequeño
  const deps = todosCanales.filter(c => (c.categoria||"").toUpperCase() === "DEPORTES");
  if (deps.length) {
    const sec = crearSeccion("⚽ Deportes", "var(--dep)", deps.length, "DEPORTES");
    sec.appendChild(crearCarruselSm(deps));
    body.appendChild(sec);
  }

  // Noticias — carrusel grande
  const nots = todosCanales.filter(c => (c.categoria||"").toUpperCase() === "NOTICIAS");
  if (nots.length) {
    const sec = crearSeccion("📰 Noticias", "var(--cel)", nots.length, "NOTICIAS");
    sec.appendChild(crearCarruselLg(nots));
    body.appendChild(sec);
  }

  // Aire — carrusel pequeño
  const aire = todosCanales.filter(c => (c.categoria||"").toUpperCase() === "AIRE");
  if (aire.length) {
    const sec = crearSeccion("📺 Canales de Aire", "var(--aire)", aire.length, "AIRE");
    sec.appendChild(crearCarruselSm(aire));
    body.appendChild(sec);
  }

  // Internacional — carrusel grande
  const intl = todosCanales.filter(c => (c.categoria||"").toUpperCase() === "INTERNACIONAL");
  if (intl.length) {
    const sec = crearSeccion("🌐 Internacional", "var(--int)", intl.length, "INTERNACIONAL");
    sec.appendChild(crearCarruselLg(intl));
    body.appendChild(sec);
  }

  // Infantil + Música — grid 2 col
  const inf = todosCanales.filter(c => (c.categoria||"").toUpperCase() === "INFANTIL");
  const mus = todosCanales.filter(c => (c.categoria||"").toUpperCase() === "MUSICA");
  if (inf.length || mus.length) {
    const grid = document.createElement("div"); grid.className = "grid2";
    if (inf.length) { const col = crearGrid2Col("👦 Infantil", "var(--inf)", inf.slice(0,5)); grid.appendChild(col); }
    if (mus.length) { const col = crearGrid2Col("🎵 Música", "var(--mus)", mus.slice(0,5)); grid.appendChild(col); }
    body.appendChild(grid);
  }

  // Historial
  if (historial.length > 0) {
    const sec = crearSeccion("🕐 Visto recientemente", null, null, null);
    historial.slice(0, 5).forEach(h => {
      const row = document.createElement("div"); row.className = "hist-row";
      const canal = todosCanales.find(c => c.nombre === h.nombre);
      const logo = canal?.logo || LOGO_DEF;
      row.innerHTML = `<div class="h-thumb"><img src="${logo}" onerror="this.src='${LOGO_DEF}'" alt="${h.nombre}"></div><div class="h-info"><div class="h-name">${h.nombre}</div><div class="h-time">${tiempoRelativo(h.ts)}</div></div><div class="h-play"><div class="ptri"></div></div>`;
      row.onclick = () => reproducir(h.url, h.nombre, h.fallbacks||[]);
      sec.appendChild(row);
    });
    body.appendChild(sec);
  }

  // Padding bottom
  const pad = document.createElement("div"); pad.style.height = "20px";
  body.appendChild(pad);
}

function crearSeccion(titulo, color, count, cat) {
  const sec = document.createElement("div"); sec.className = "row-sec";
  const hdr = document.createElement("div"); hdr.className = "row-hdr";
  const t = document.createElement("div"); t.className = "row-title";
  if (color) t.style.color = color;
  t.textContent = titulo + (count ? "" : "");
  hdr.appendChild(t);
  if (cat && count) {
    const ver = document.createElement("div"); ver.className = "row-ver";
    ver.textContent = "Ver todos (" + count + ")";
    ver.onclick = () => filtrarCat(cat, null);
    hdr.appendChild(ver);
  }
  sec.appendChild(hdr);
  return sec;
}

function crearCarruselSm(lista) {
  const car = document.createElement("div"); car.className = "car-sm";
  lista.slice(0, 20).forEach(c => {
    const item = document.createElement("div"); item.className = "ch-sm";
    const logo = document.createElement("div"); logo.className = "ch-sm-logo" + (canalActivo===c.nombre?" a":"");
    logo.innerHTML = `<img src="${c.logo||LOGO_DEF}" onerror="this.src='${LOGO_DEF}'" alt="${c.nombre}"><div class="ldot"></div>`;
    const name = document.createElement("div"); name.className = "ch-sm-name"; name.textContent = c.nombre;
    item.appendChild(logo); item.appendChild(name);
    item.onclick = () => { reproducir(c.url, c.nombre, c.fallbacks||[]); renderTV(); };
    car.appendChild(item);
  });
  return car;
}

function crearCarruselLg(lista) {
  const car = document.createElement("div"); car.className = "car-lg";
  lista.slice(0, 15).forEach(c => {
    const item = document.createElement("div"); item.className = "ch-lg" + (canalActivo===c.nombre?" a":"");
    item.innerHTML = `
      <div class="ch-lg-img">
        <img src="${c.logo||LOGO_DEF}" onerror="this.src='${LOGO_DEF}'" alt="${c.nombre}">
        <div class="ch-lg-live">EN VIVO</div>
      </div>
      <div class="ch-lg-info">
        <div class="ch-lg-name">${c.nombre}</div>
        <div class="ch-lg-cat">${c.categoria||""}</div>
      </div>`;
    item.onclick = () => { reproducir(c.url, c.nombre, c.fallbacks||[]); renderTV(); };
    car.appendChild(item);
  });
  return car;
}

function crearGrid2Col(titulo, color, lista) {
  const col = document.createElement("div"); col.className = "grid2-col";
  const t = document.createElement("div"); t.className = "grid2-title"; t.style.color = color; t.textContent = titulo;
  col.appendChild(t);
  lista.forEach(c => {
    const row = document.createElement("div"); row.className = "grid2-row";
    row.innerHTML = `<div class="grid2-thumb"><img src="${c.logo||LOGO_DEF}" onerror="this.src='${LOGO_DEF}'" alt="${c.nombre}"></div><div class="grid2-name">${c.nombre}</div>`;
    row.onclick = () => reproducir(c.url, c.nombre, c.fallbacks||[]);
    col.appendChild(row);
  });
  return col;
}

function renderGrillaCanales(container, lista, cat) {
  if (!lista.length) { container.innerHTML = '<p style="color:var(--muted);text-align:center;padding:30px;">No hay canales en esta categoría</p>'; return; }
  const wrap = document.createElement("div"); wrap.style.cssText = "display:grid;grid-template-columns:repeat(auto-fill,minmax(80px,1fr));gap:10px;padding:10px 14px 80px;";
  lista.forEach(c => {
    const card = document.createElement("div");
    card.style.cssText = "background:var(--card);border-radius:var(--rad);padding:10px 6px;text-align:center;cursor:pointer;border:1.5px solid " + (canalActivo===c.nombre?"var(--dor)":"rgba(139,92,246,0.15)") + ";display:flex;flex-direction:column;align-items:center;gap:5px;";
    card.innerHTML = `<div class="ldot" style="position:static;"></div><img src="${c.logo||LOGO_DEF}" onerror="this.src='${LOGO_DEF}'" alt="${c.nombre}" style="width:44px;height:44px;object-fit:contain;border-radius:6px;"><div style="font-size:10px;font-weight:600;line-height:1.2;">${c.nombre}</div>`;
    card.onclick = () => { reproducir(c.url, c.nombre, c.fallbacks||[]); renderGrillaCanales(container, lista, cat); };
    wrap.appendChild(card);
  });
  container.appendChild(wrap);
}

