<!DOCTYPE html>
<html lang="es" class="dark">
<head><%- include('partials/head', { title: 'StreamX — Catálogo' }) %></head>
<meta name="monetag" content="0a7b83f78e5381146bfabc4e5050fe6d">
<body class="bg-zinc-950 text-zinc-100 antialiased overflow-x-hidden">

<div class="flex min-h-screen">

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- NAV LATERAL                                                 -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <aside id="sidebar"
    class="fixed top-0 left-0 z-40 h-full w-56 bg-zinc-900/95 border-r border-zinc-800/60 backdrop-blur-md
           flex flex-col transition-transform duration-300
           -translate-x-full lg:translate-x-0">

    <!-- Logo -->
    <div class="px-5 py-6 border-b border-zinc-800/60">
      <a href="/" class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-violet-600 to-violet-800 flex items-center justify-center font-black text-white text-base shadow-lg shadow-violet-900/40">S</div>
        <div>
          <p class="font-bold text-white text-base leading-none">StreamX</p>
          <p class="text-[10px] text-zinc-500 mt-0.5">TECNOCOM</p>
        </div>
      </a>
    </div>

    <!-- Nav links -->
    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">

      <a href="/" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all
        <%= (!activeType || activeType === '') && !activeGenre && !searchQuery ? 'bg-violet-600/20 text-violet-300 border border-violet-500/20' : 'text-zinc-400 hover:text-white hover:bg-zinc-800/60' %>">
        <svg class="w-4.5 h-4.5 shrink-0" style="width:18px;height:18px" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        Inicio
      </a>

      <a href="/?type=movie" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all
        <%= activeType === 'movie' ? 'bg-violet-600/20 text-violet-300 border border-violet-500/20' : 'text-zinc-400 hover:text-white hover:bg-zinc-800/60' %>">
        <svg style="width:18px;height:18px;flex-shrink:0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/>
        </svg>
        Películas
      </a>

      <a href="/?type=series" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all
        <%= activeType === 'series' ? 'bg-violet-600/20 text-violet-300 border border-violet-500/20' : 'text-zinc-400 hover:text-white hover:bg-zinc-800/60' %>">
        <svg style="width:18px;height:18px;flex-shrink:0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
        Series
      </a>

      <a href="/tv" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-zinc-400 hover:text-white hover:bg-zinc-800/60 transition-all">
        <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse shrink-0"></span>
        TV en Vivo
      </a>

      <!-- Géneros -->
      <% if (typeof genres !== 'undefined' && genres.length > 0) { %>
      <div class="pt-4 pb-1">
        <p class="px-3 text-[10px] font-semibold text-zinc-600 uppercase tracking-widest">Géneros</p>
      </div>
      <% genres.slice(0, 12).forEach(function(g) { %>
      <a href="/?genre=<%= encodeURIComponent(g) %>"
        class="flex items-center gap-3 px-3 py-2 rounded-xl text-xs font-medium transition-all
          <%= activeGenre === g ? 'bg-violet-600/20 text-violet-300' : 'text-zinc-500 hover:text-white hover:bg-zinc-800/60' %>">
        <span class="w-1.5 h-1.5 rounded-full bg-zinc-600 shrink-0"></span>
        <%= g %>
      </a>
      <% }); %>
      <% } %>
    </nav>

    <!-- Admin link -->
    <div class="px-3 py-4 border-t border-zinc-800/60">
      <a href="/admin/login" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-xs text-zinc-500 hover:text-white hover:bg-zinc-800/60 transition-all">
        <svg style="width:16px;height:16px;flex-shrink:0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Admin
      </a>
    </div>
  </aside>

  <!-- Overlay mobile -->
  <div id="overlay" class="fixed inset-0 bg-black/60 z-30 hidden lg:hidden" onclick="closeSidebar()"></div>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- CONTENIDO PRINCIPAL                                         -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <div class="flex-1 lg:ml-56 min-w-0">

    <!-- Top bar mobile -->
    <header class="lg:hidden sticky top-0 z-20 bg-zinc-950/90 backdrop-blur border-b border-zinc-800/60 px-4 py-3 flex items-center gap-3">
      <button onclick="openSidebar()" class="text-zinc-400 hover:text-white transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
      <div class="flex items-center gap-2">
        <div class="w-6 h-6 rounded-lg bg-violet-600 flex items-center justify-center font-bold text-white text-xs">S</div>
        <span class="font-bold text-white text-sm">StreamX</span>
      </div>
      <!-- Búsqueda mobile -->
      <form method="GET" action="/" class="flex-1">
        <input type="text" name="q" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
          placeholder="Buscar..."
          class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-1.5 text-sm text-white placeholder-zinc-500 focus:outline-none focus:border-violet-500 transition" />
      </form>
    </header>

    <!-- Búsqueda desktop (dentro del contenido) -->
    <div class="hidden lg:block px-6 pt-5 pb-0">
      <form method="GET" action="/" class="flex items-center gap-3 max-w-lg">
        <div class="relative flex-1">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input type="text" name="q" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
            placeholder="Buscar películas, series..."
            class="w-full bg-zinc-800/60 border border-zinc-700/60 rounded-xl pl-9 pr-4 py-2.5 text-sm text-white placeholder-zinc-500 focus:outline-none focus:border-violet-500 focus:bg-zinc-800 transition" />
          <% if (activeType) { %><input type="hidden" name="type" value="<%= activeType %>" /><% } %>
        </div>
      </form>
    </div>

    <!-- Error -->
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="mx-6 mt-4 rounded-lg border border-red-800 bg-red-950/40 px-4 py-3 text-sm text-red-300"><%= error %></div>
    <% } %>
<!-- inicio Adsterra Banner 728x90 -->
    <div id="ad-banner-top" style="display:flex;justify-content:center;background:#000;padding:4px 0;flex-shrink:0;overflow:hidden;max-height:100px;">
      <script>
      atOptions = {
        'key' : '4bf9d7191ce39ecab2e473f31afb4744',
        'format' : 'iframe',
        'height' : 90,
        'width' : 728,
        'params' : {}
      };
    </script>
    <script src="https://balancedsuppercreed.com/4bf9d7191ce39ecab2e473f31afb4744/invoke.js"></script>

    </div>
<!--fin Adsterra Banner 728x90 -->
    <!-- ─── HERO SECTION ──────────────────────────────────────── -->
    <% var hero = typeof heroItem !== 'undefined' ? heroItem : null; %>
    <% if (hero && !searchQuery && !activeGenre && !activeType) { %>
    <section class="px-4 lg:px-6 pt-5 pb-2">
      <div class="relative rounded-2xl overflow-hidden"
           style="min-height: 380px; max-height: 460px;">

        <!-- Backdrop -->
        <% if (hero.backdropPath) { %>
        <div class="absolute inset-0">
          <img src="<%= hero.backdropPath %>" alt="" class="w-full h-full object-cover object-center" loading="eager" />
          <!-- Gradientes -->
          <div class="absolute inset-0 bg-gradient-to-r from-zinc-950 via-zinc-950/70 to-transparent"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/90 via-transparent to-transparent"></div>
        </div>
        <% } else { %>
        <div class="absolute inset-0 bg-gradient-to-br from-violet-900/40 to-zinc-900"></div>
        <% } %>

        <!-- Contenido hero -->
        <div class="relative z-10 flex h-full items-end p-6 lg:p-10" style="min-height: 380px;">
          <div class="max-w-lg">
            <!-- Badge tipo -->
            <span class="inline-flex items-center gap-1.5 text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full mb-3
              <%= hero.kind === 'series' ? 'bg-blue-600/30 text-blue-300 border border-blue-500/30' : 'bg-violet-600/30 text-violet-300 border border-violet-500/30' %>">
              <% if (hero.kind === 'series') { %>
              <svg style="width:10px;height:10px" fill="currentColor" viewBox="0 0 24 24"><path d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              Serie
              <% } else { %>
              <svg style="width:10px;height:10px" fill="currentColor" viewBox="0 0 24 24"><path d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18"/></svg>
              Película
              <% } %>
            </span>

            <!-- Título -->
            <h2 class="text-3xl lg:text-4xl font-black text-white leading-tight mb-2 drop-shadow-lg">
              <%= hero.title %>
            </h2>

            <!-- Año + géneros -->
            <div class="flex items-center gap-2 flex-wrap mb-3">
              <% var heroYear = (hero.releaseDate || hero.firstAirDate || '').slice(0,4); %>
              <% if (heroYear) { %><span class="text-sm text-zinc-400 font-medium"><%= heroYear %></span><% } %>
              <% if (hero.genres && hero.genres.length > 0) { %>
              <% hero.genres.slice(0,3).forEach(function(g, i) { %>
              <% if (i > 0 || heroYear) { %><span class="text-zinc-600 text-xs">•</span><% } %>
              <span class="text-sm text-zinc-300"><%= g %></span>
              <% }); %>
              <% } %>
              <% if (hero.viewCount > 0) { %>
              <span class="text-zinc-600 text-xs">•</span>
              <span class="text-xs text-zinc-400 flex items-center gap-1">
                <svg style="width:12px;height:12px" fill="currentColor" viewBox="0 0 24 24"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                <%= hero.viewCount.toLocaleString('es-AR') %>
              </span>
              <% } %>
            </div>

            <!-- Sinopsis recortada -->
            <% if (hero.overview) { %>
            <p class="text-sm text-zinc-300 leading-relaxed mb-5 line-clamp-2 max-w-sm drop-shadow">
              <%= hero.overview %>
            </p>
            <% } %>

            <!-- CTA -->
            <a href="<%= hero.kind === 'series' ? '/watch/series/' + hero._id : '/watch/movie/' + hero._id %>"
              class="inline-flex items-center gap-2 bg-violet-600 hover:bg-violet-500 text-white font-bold text-sm px-6 py-3 rounded-xl transition-all shadow-lg shadow-violet-900/40 hover:shadow-violet-700/50 hover:scale-105 active:scale-100">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              Ver ahora
            </a>
          </div>
        </div>

        <!-- Poster flotante (desktop) -->
        <% if (hero.posterPath) { %>
        <div class="absolute right-8 bottom-0 hidden lg:block" style="width:130px">
          <img src="<%= hero.posterPath %>" alt="" class="w-full rounded-t-xl shadow-2xl border border-zinc-700/50" style="height:195px;object-fit:cover" />
        </div>
        <% } %>
      </div>
    </section>
    <% } %>

    <!-- ─── CATÁLOGO ───────────────────────────────────────────── -->
    <section class="px-4 lg:px-6 py-6">

      <!-- Header sección -->
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-bold text-white">
          <% if (searchQuery) { %>
            Resultados para "<%= searchQuery %>"
            <a href="/" class="ml-2 text-xs text-violet-400 font-normal hover:underline">limpiar</a>
          <% } else if (activeGenre) { %>
            Género: <%= activeGenre %>
            <a href="/" class="ml-2 text-xs text-violet-400 font-normal hover:underline">limpiar</a>
          <% } else if (activeType === 'movie') { %>
            Películas
          <% } else if (activeType === 'series') { %>
            Series
          <% } else { %>
            Recién añadidos
          <% } %>
        </h3>
        <% if (typeof pagination !== 'undefined' && pagination) { %>
        <span class="text-xs text-zinc-500"><%= pagination.totalItems %> títulos</span>
        <% } %>
      </div>

      <!-- Grid -->
      <% var items = typeof catalogItems !== 'undefined' ? catalogItems : []; %>
      <% if (!items || items.length === 0) { %>
      <div class="flex flex-col items-center justify-center py-24 text-center">
        <div class="w-16 h-16 rounded-full bg-zinc-800/60 flex items-center justify-center mb-4">
          <svg class="w-7 h-7 text-zinc-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
        </div>
        <p class="text-zinc-500 text-sm">No hay contenido aún.</p>
        <a href="/admin/login" class="mt-2 text-violet-400 text-xs hover:underline">Importar desde el panel →</a>
      </div>

      <% } else { %>
      <div class="grid grid-cols-3 gap-2.5 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-5 xl:grid-cols-6 2xl:grid-cols-7">
        <% items.forEach(function(item) { %>
        <a href="<%= item.kind === 'series' ? '/watch/series/' + item._id : '/watch/movie/' + item._id %>"
          class="group block overflow-hidden rounded-xl border border-zinc-800/60 bg-zinc-900/40 transition-all duration-300
                 hover:border-violet-500/50 hover:scale-[1.03] hover:shadow-xl hover:shadow-violet-900/20 hover:z-10 relative">

          <!-- Poster -->
          <div class="relative overflow-hidden bg-zinc-800" style="padding-top:150%">
            <% if (item.posterPath) { %>
            <img src="<%= item.posterPath %>" alt="<%= item.title %>"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy" decoding="async" />
            <% } else { %>
            <div class="absolute inset-0 flex items-center justify-center bg-zinc-800">
              <svg class="w-8 h-8 text-zinc-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14"/>
              </svg>
            </div>
            <% } %>

            <!-- Overlay hover -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center">
              <div class="w-11 h-11 rounded-full bg-violet-600/90 flex items-center justify-center shadow-lg transform scale-75 group-hover:scale-100 transition-transform duration-300">
                <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </div>
            </div>

            <!-- Badges top -->
            <div class="absolute top-1.5 left-1.5 flex flex-col gap-1">
              <span class="text-[9px] font-bold uppercase tracking-wide px-1.5 py-0.5 rounded-md
                <%= item.kind === 'series' ? 'bg-blue-600/90 text-white' : 'bg-violet-600/90 text-white' %>">
                <%= item.kind === 'series' ? 'Serie' : 'Peli' %>
              </span>
              <% if (item.featured) { %>
              <span class="text-[9px] font-bold bg-yellow-500 text-black px-1.5 py-0.5 rounded-md">★</span>
              <% } %>
            </div>
          </div>

          <!-- Info -->
          <div class="p-2">
            <h2 class="text-xs font-semibold text-zinc-200 group-hover:text-violet-300 transition-colors leading-snug line-clamp-2">
              <%= item.title %>
            </h2>
            <% var fecha = item.releaseDate || item.firstAirDate; %>
            <p class="text-[10px] text-zinc-600 mt-0.5"><%= fecha ? fecha.slice(0,4) : '' %></p>
          </div>
        </a>
        <% }); %>
      </div>

      <!-- Paginación -->
      <% if (typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1) { %>
      <div class="mt-10 flex items-center justify-center gap-2">
        <% if (pagination.page > 1) { %>
        <a href="?page=<%= pagination.page - 1 %><%= activeType ? '&type='+activeType : '' %><%= activeGenre ? '&genre='+activeGenre : '' %><%= searchQuery ? '&q='+searchQuery : '' %>"
          class="px-4 py-2 rounded-xl bg-zinc-800 text-zinc-300 text-sm hover:bg-zinc-700 transition">← Anterior</a>
        <% } %>
        <span class="px-4 py-2 text-sm text-zinc-500">Página <%= pagination.page %> de <%= pagination.totalPages %></span>
        <% if (pagination.page < pagination.totalPages) { %>
        <a href="?page=<%= pagination.page + 1 %><%= activeType ? '&type='+activeType : '' %><%= activeGenre ? '&genre='+activeGenre : '' %><%= searchQuery ? '&q='+searchQuery : '' %>"
          class="px-4 py-2 rounded-xl bg-zinc-800 text-zinc-300 text-sm hover:bg-zinc-700 transition">Siguiente →</a>
        <% } %>
      </div>
      <% } %>

      <% } %>
    </section>

    <footer class="px-6 pb-6 text-xs text-zinc-700 text-center">
      StreamX &copy; <%= new Date().getFullYear() %> — TECNOCOM
    </footer>
  </div>
</div>

<script>
function openSidebar() {
  document.getElementById('sidebar').classList.remove('-translate-x-full');
  document.getElementById('overlay').classList.remove('hidden');
  document.body.style.overflow = 'hidden';
}
function closeSidebar() {
  document.getElementById('sidebar').classList.add('-translate-x-full');
  document.getElementById('overlay').classList.add('hidden');
  document.body.style.overflow = '';
}
// Cerrar con ESC
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeSidebar();
});
</script>
</body>
</html>
