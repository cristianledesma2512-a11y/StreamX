<!DOCTYPE html>
<html lang="es" class="dark">
<head><%- include('../partials/head', { title: 'Dashboard — StreamX Admin' }) %></head>
<body class="bg-zinc-950 text-zinc-100 min-h-screen flex antialiased">
<%- include('partials/nav') %>

<div class="flex-1 overflow-y-auto">
  <div class="max-w-6xl mx-auto px-6 py-8">

    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-white">Dashboard</h1>
        <p class="text-sm text-zinc-500 mt-0.5">Hola, <span class="text-zinc-300"><%= adminUser.username %></span> — <%= new Date().toLocaleDateString('es-AR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
      </div>
      <form method="POST" action="/admin/flush-cache">
        <button type="submit" class="text-xs text-zinc-500 hover:text-white border border-zinc-700 hover:border-zinc-500 px-3 py-1.5 rounded-lg transition">
          Limpiar cache
        </button>
      </form>
    </div>

    <% if (typeof msg !== 'undefined' && msg) { %>
    <div class="mb-6 rounded-lg bg-green-950/50 border border-green-800 px-4 py-3 text-sm text-green-300"><%= msg %></div>
    <% } %>

    <!-- Stats cards -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">
      <% const cards = [
        { label: 'Películas', value: stats.movieCount, color: 'violet' },
        { label: 'Series', value: stats.seriesCount, color: 'blue' },
        { label: 'Vistas totales', value: stats.totalPageViews, color: 'emerald' },
        { label: 'Vistas hoy', value: stats.viewsToday, color: 'yellow' },
        { label: 'Admins', value: stats.adminCount, color: 'zinc' },
      ]; %>
      <% cards.forEach(function(c) { %>
      <div class="rounded-xl border border-zinc-800 bg-zinc-900/60 p-4">
        <p class="text-xs text-zinc-500 font-medium mb-1"><%= c.label %></p>
        <p class="text-2xl font-bold text-white"><%= c.value.toLocaleString('es-AR') %></p>
      </div>
      <% }); %>
    </div>

    <!-- Charts + tops -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">

      <!-- Gráfico de visitas (últimos 7 días) -->
      <div class="rounded-xl border border-zinc-800 bg-zinc-900/60 p-5">
        <h2 class="text-sm font-semibold text-white mb-4">Visitas — últimos 7 días</h2>
        <% if (!viewsByDay || viewsByDay.length === 0) { %>
        <p class="text-sm text-zinc-600">Sin datos aún.</p>
        <% } else { %>
        <div class="flex items-end gap-1.5 h-28">
          <% const maxVal = Math.max(...viewsByDay.map(function(d) { return d.count; }), 1); %>
          <% viewsByDay.forEach(function(d) { %>
          <div class="flex-1 flex flex-col items-center gap-1 group">
            <span class="text-[9px] text-zinc-600 opacity-0 group-hover:opacity-100 transition"><%= d.count %></span>
            <div class="w-full rounded-t-md bg-violet-600/70 group-hover:bg-violet-500 transition"
              style="height: <%= Math.max(4, Math.round((d.count / maxVal) * 96)) %>px"></div>
            <span class="text-[9px] text-zinc-600"><%= d._id.slice(5) %></span>
          </div>
          <% }); %>
        </div>
        <% } %>
      </div>

      <!-- Top contenido -->
      <div class="rounded-xl border border-zinc-800 bg-zinc-900/60 p-5">
        <h2 class="text-sm font-semibold text-white mb-4">Top contenido</h2>
        <div class="space-y-2">
          <% const top = [...topMovies.map(function(m){ return {...m, kind:'movie'}; }), ...topSeries.map(function(s){ return {...s, kind:'series'}; })].sort(function(a,b){ return b.viewCount - a.viewCount; }).slice(0,6); %>
          <% top.forEach(function(item) { %>
          <div class="flex items-center justify-between gap-2">
            <div class="flex items-center gap-2 min-w-0">
              <span class="text-[9px] px-1.5 py-0.5 rounded font-bold <%= item.kind === 'series' ? 'bg-blue-900/50 text-blue-400' : 'bg-violet-900/50 text-violet-400' %>">
                <%= item.kind === 'series' ? 'S' : 'P' %>
              </span>
              <span class="text-sm text-zinc-300 truncate"><%= item.title %></span>
            </div>
            <span class="shrink-0 text-xs text-zinc-500"><%= item.viewCount %> v.</span>
          </div>
          <% }); %>
        </div>
      </div>
    </div>

    <!-- Importar rápido -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="rounded-xl border border-zinc-800 bg-zinc-900/60 p-5">
        <h2 class="text-sm font-semibold text-white mb-4">Importar película</h2>
        <form method="POST" action="/admin/movies/import" class="flex gap-2">
          <input type="number" name="tmdbId" placeholder="ID de TMDB..." required
            class="flex-1 bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-violet-500 transition placeholder-zinc-600" />
          <button type="submit" class="bg-violet-600 hover:bg-violet-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition">
            Importar
          </button>
        </form>
      </div>
      <div class="rounded-xl border border-zinc-800 bg-zinc-900/60 p-5">
        <h2 class="text-sm font-semibold text-white mb-4">Importar serie</h2>
        <form method="POST" action="/admin/series/import" class="flex gap-2">
          <input type="number" name="tmdbId" placeholder="ID de TMDB..." required
            class="flex-1 bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-violet-500 transition placeholder-zinc-600" />
          <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition">
            Importar
          </button>
        </form>
      </div>
    </div>

  </div>
</div>
</body>
</html>
