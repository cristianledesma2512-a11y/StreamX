<!DOCTYPE html>
<html lang="es" class="dark">
<head>
<%- include('partials/head', { title: 'TV en Vivo — StreamX' }) %>
<script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-database.js"></script>
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<style>
:root{
  --az:#09090b;--az2:#18181b;--cel:#8b5cf6;--dor:#a78bfa;
  --roj:#7c3aed;--bg:#09090b;--card:#18181b;--card2:#27272a;
  --txt:#f4f4f5;--muted:#71717a;--rad:12px;
  --dep:#10b981;--not:#8b5cf6;--aire:#c084fc;
  --mus:#f59e0b;--inf:#60a5fa;--int:#7c3aed;
  --borde:rgba(139,92,246,0.25);
}



:root{
  --az:#09090b;--az2:#18181b;--cel:#8b5cf6;--dor:#a78bfa;
  --roj:#7c3aed;--bg:#09090b;--card:#18181b;--card2:#27272a;
  --txt:#f4f4f5;--muted:#71717a;--rad:12px;
  --dep:#10b981;--not:#8b5cf6;--aire:#c084fc;
  --mus:#f59e0b;--inf:#60a5fa;--int:#7c3aed;
}

*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;overflow:hidden;}
body{background:var(--bg);color:var(--txt);font-family:'Segoe UI',system-ui,sans-serif;display:flex;flex-direction:column;}

/* ── HEADER ── */
#hdr{background:var(--az2);padding:11px 14px;display:flex;align-items:center;gap:10px;border-bottom:1.5px solid var(--dor);flex-shrink:0;z-index:50;}
.logo{font-size:15px;font-weight:700;letter-spacing:.5px;flex:1;}
.logo span{color:var(--cel);}
.icon-btn{width:32px;height:32px;border-radius:50%;background:rgba(139,92,246,0.12);border:1px solid rgba(139,92,246,0.25);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;}
.avatar{width:32px;height:32px;border-radius:50%;background:rgba(167,139,250,0.2);border:1px solid var(--dor);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--cel);cursor:pointer;flex-shrink:0;}

/* ── SEARCH ── */
#srch-bar{background:var(--az);padding:8px 14px;border-bottom:1px solid rgba(139,92,246,0.1);flex-shrink:0;}
#srch-input{width:100%;background:var(--card);border:1px solid rgba(139,92,246,0.2);border-radius:20px;padding:8px 14px 8px 36px;color:var(--txt);font-size:13px;outline:none;position:relative;}
.srch-wrap{position:relative;}
.srch-wrap svg{position:absolute;left:12px;top:50%;transform:translateY(-50%);pointer-events:none;}
#srch-input::placeholder{color:var(--muted);}

/* ── NAV TABS ── */
#nav-tabs{display:flex;background:rgba(0,0,0,0.3);border-bottom:1px solid rgba(139,92,246,0.1);overflow-x:auto;scrollbar-width:none;flex-shrink:0;}
#nav-tabs::-webkit-scrollbar{display:none;}
.ntab{flex-shrink:0;padding:10px 15px;font-size:11px;font-weight:700;color:var(--muted);border-bottom:2px solid transparent;cursor:pointer;white-space:nowrap;letter-spacing:.3px;}
.ntab.a{color:var(--dor);border-bottom-color:var(--dor);}

/* ── MAIN SCROLL AREA ── */
#main{flex:1;overflow-y:auto;overflow-x:hidden;scrollbar-width:thin;scrollbar-color:rgba(139,92,246,0.2) transparent;}
#main::-webkit-scrollbar{width:3px;}
#main::-webkit-scrollbar-thumb{background:rgba(139,92,246,0.2);border-radius:2px;}

/* ── SECTIONS ── */
.section{display:none;}
.section.a{display:block;}

/* ── CATEGORY STRIP ── */
#cat-strip{display:flex;gap:8px;overflow-x:auto;scrollbar-width:none;padding:10px 14px 8px;background:rgba(0,0,0,0.2);border-bottom:1px solid rgba(139,92,246,0.08);flex-shrink:0;}
#cat-strip::-webkit-scrollbar{display:none;}
.cat-pill{flex-shrink:0;display:flex;align-items:center;gap:5px;padding:6px 12px;border-radius:20px;font-size:11px;font-weight:700;cursor:pointer;border:1.5px solid transparent;white-space:nowrap;}
.cat-pill.all{background:var(--dor);color:#09090b;border-color:var(--dor);}
.cat-pill.dep{background:rgba(46,204,113,0.15);color:var(--dep);border-color:rgba(46,204,113,0.3);}
.cat-pill.not{background:rgba(139,92,246,0.15);color:var(--cel);border-color:rgba(139,92,246,0.3);}
.cat-pill.aire{background:rgba(155,89,182,0.15);color:var(--aire);border-color:rgba(155,89,182,0.3);}
.cat-pill.mus{background:rgba(230,126,34,0.15);color:var(--mus);border-color:rgba(230,126,34,0.3);}
.cat-pill.inf{background:rgba(52,152,219,0.15);color:var(--inf);border-color:rgba(52,152,219,0.3);}
.cat-pill.int{background:rgba(231,76,60,0.15);color:var(--int);border-color:rgba(231,76,60,0.3);}

/* ── PLAYER HERO ── */
#player-hero{position:relative;background:#000;width:100%;aspect-ratio:16/9;max-height:210px;flex-shrink:0;}
#video-el{width:100%;height:100%;display:block;background:#000;}
#iframe-el{width:100%;height:100%;border:none;display:none;}
#hero-overlay{position:absolute;inset:0;pointer-events:none;}
#hero-badge{position:absolute;top:8px;left:10px;background:var(--roj);color:#fff;font-size:9px;font-weight:700;padding:3px 8px;border-radius:4px;letter-spacing:1px;}
#hero-info{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,0.85));padding:18px 12px 8px;}
#hero-canal{font-size:15px;font-weight:700;color:var(--dor);}
#hero-sub{font-size:11px;color:rgba(255,255,255,0.55);margin-top:2px;}
#hero-btns{position:absolute;top:8px;right:8px;display:flex;gap:6px;}
.hero-btn{width:30px;height:30px;border-radius:50%;background:rgba(0,0,0,0.5);border:1px solid rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;cursor:pointer;pointer-events:all;}
#hero-quality{display:none;position:absolute;bottom:40px;right:8px;background:rgba(0,20,40,0.95);border:1px solid var(--borde, rgba(139,92,246,0.3));border-radius:8px;padding:6px;pointer-events:all;flex-direction:column;gap:4px;}
.q-btn{background:rgba(255,255,255,0.08);border:1px solid rgba(139,92,246,0.2);color:var(--txt);padding:4px 12px;border-radius:10px;font-size:11px;cursor:pointer;text-align:center;}
.q-btn.a{background:var(--dor);border-color:var(--dor);color:var(--az);}
#hero-spinner{display:none;position:absolute;inset:0;background:rgba(0,0,0,0.6);align-items:center;justify-content:center;pointer-events:none;}
.spin{width:36px;height:36px;border:3px solid rgba(255,255,255,0.15);border-top-color:var(--cel);border-radius:50%;animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
#hero-err{display:none;position:absolute;inset:0;background:rgba(0,0,0,0.85);align-items:center;justify-content:center;flex-direction:column;gap:10px;text-align:center;padding:20px;pointer-events:all;}
#hero-err p{color:rgba(255,255,255,0.6);font-size:13px;}
#hero-err button{background:var(--roj);border:none;color:#fff;padding:8px 20px;border-radius:6px;cursor:pointer;font-weight:700;}
#hero-placeholder{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:10px;background:linear-gradient(135deg,var(--az2),#1a0a2e);}
#hero-placeholder p{color:var(--muted);font-size:13px;}

/* ── TV SECTION BODY ── */
#tv-body{overflow-y:auto;}

/* ── ROW SECTION ── */
.row-sec{padding:12px 0 6px;}
.row-hdr{display:flex;align-items:center;justify-content:space-between;padding:0 14px 8px;}
.row-title{font-size:13px;font-weight:700;}
.row-ver{font-size:11px;color:var(--cel);cursor:pointer;}

/* Favoritos chips */
.fav-strip{display:flex;gap:8px;overflow-x:auto;scrollbar-width:none;padding:0 14px 4px;}
.fav-strip::-webkit-scrollbar{display:none;}
.fav-pill{flex-shrink:0;background:var(--card2);border-radius:20px;padding:6px 12px;display:flex;align-items:center;gap:6px;border:1px solid rgba(139,92,246,0.15);cursor:pointer;}
.fav-pill.a{border-color:var(--dor);background:rgba(167,139,250,0.1);}
.fav-pill.add{border-style:dashed;color:var(--muted);font-size:11px;font-weight:600;}
.fdot{width:6px;height:6px;border-radius:50%;background:var(--roj);}
.fname{font-size:11px;font-weight:600;}

/* Carrusel pequeño (iconos) */
.car-sm{display:flex;gap:10px;overflow-x:auto;scrollbar-width:none;padding:0 14px 4px;}
.car-sm::-webkit-scrollbar{display:none;}
.ch-sm{flex-shrink:0;width:72px;display:flex;flex-direction:column;align-items:center;gap:5px;cursor:pointer;}
.ch-sm-logo{width:60px;height:60px;background:var(--card);border-radius:var(--rad);border:1.5px solid rgba(139,92,246,0.15);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;transition:.15s;}
.ch-sm-logo.a{border-color:var(--dor);background:rgba(167,139,250,0.12);}
.ch-sm-logo img{width:100%;height:100%;object-fit:contain;padding:6px;}
.ch-sm-name{font-size:10px;font-weight:600;text-align:center;line-height:1.2;color:var(--txt);}
.ldot{position:absolute;top:4px;right:4px;width:6px;height:6px;border-radius:50%;background:var(--roj);animation:blink 1.5s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

/* Carrusel grande (cards) */
.car-lg{display:flex;gap:10px;overflow-x:auto;scrollbar-width:none;padding:0 14px 4px;}
.car-lg::-webkit-scrollbar{display:none;}
.ch-lg{flex-shrink:0;width:136px;background:var(--card);border-radius:var(--rad);border:1px solid rgba(139,92,246,0.15);overflow:hidden;cursor:pointer;transition:.15s;}
.ch-lg.a{border-color:var(--dor);}
.ch-lg-img{height:74px;background:linear-gradient(135deg,var(--az2),#1a0a2e);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;}
.ch-lg-img img{width:100%;height:100%;object-fit:contain;padding:8px;}
.ch-lg-live{position:absolute;bottom:5px;left:5px;background:var(--roj);color:#fff;font-size:8px;font-weight:700;padding:2px 5px;border-radius:3px;}
.ch-lg-info{padding:7px 8px;}
.ch-lg-name{font-size:12px;font-weight:600;}
.ch-lg-cat{font-size:10px;color:var(--muted);margin-top:1px;}

/* Grid 2 columnas Infantil+Música */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:0;border-top:1px solid rgba(139,92,246,0.08);}
.grid2-col{padding:10px 14px;}
.grid2-col:first-child{border-right:1px solid rgba(139,92,246,0.08);}
.grid2-title{font-size:12px;font-weight:700;margin-bottom:8px;}
.grid2-row{display:flex;align-items:center;gap:6px;padding:3px 0;cursor:pointer;}
.grid2-thumb{width:28px;height:28px;background:var(--card);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:8px;color:var(--muted);overflow:hidden;flex-shrink:0;}
.grid2-thumb img{width:100%;height:100%;object-fit:contain;padding:3px;}
.grid2-name{font-size:11px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}

/* Historial */
.hist-row{display:flex;align-items:center;gap:10px;padding:8px 14px;border-bottom:1px solid rgba(139,92,246,0.06);cursor:pointer;}
.h-thumb{width:50px;height:32px;background:var(--card);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:9px;color:var(--muted);flex-shrink:0;overflow:hidden;}
.h-thumb img{width:100%;height:100%;object-fit:contain;padding:4px;}
.h-info{flex:1;}
.h-name{font-size:12px;font-weight:600;}
.h-time{font-size:10px;color:var(--muted);margin-top:1px;}
.h-play{width:28px;height:28px;border-radius:50%;background:rgba(167,139,250,0.15);border:1px solid var(--dor);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.ptri{width:0;height:0;border-top:4px solid transparent;border-bottom:4px solid transparent;border-left:8px solid var(--dor);margin-left:2px;}

/* Búsqueda resultados */
#srch-results{padding:8px 14px;}
.srch-item{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(139,92,246,0.06);cursor:pointer;}
.srch-thumb{width:40px;height:40px;background:var(--card);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:9px;color:var(--muted);flex-shrink:0;overflow:hidden;}
.srch-thumb img{width:100%;height:100%;object-fit:contain;padding:4px;}
.srch-info{flex:1;}
.srch-name{font-size:13px;font-weight:600;}
.srch-cat{font-size:11px;color:var(--muted);}
.srch-play{width:32px;height:32px;border-radius:50%;background:rgba(167,139,250,0.15);border:1px solid var(--dor);display:flex;align-items:center;justify-content:center;}

/* Skeleton */
.skel{background:linear-gradient(90deg,rgba(255,255,255,0.04) 25%,rgba(255,255,255,0.08) 50%,rgba(255,255,255,0.04) 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:var(--rad);}
@keyframes shimmer{to{background-position:-200% 0;}}

/* Secciones de contenido */
.msec-wrap{padding:0 0 80px;}
.sub-tabs{display:flex;gap:8px;overflow-x:auto;scrollbar-width:none;padding:12px 14px 8px;}
.sub-tabs::-webkit-scrollbar{display:none;}
.stab{flex-shrink:0;padding:7px 14px;background:rgba(255,255,255,0.07);border:1px solid rgba(139,92,246,0.2);color:rgba(255,255,255,0.6);border-radius:20px;font-size:11px;font-weight:700;cursor:pointer;}
.stab.a{background:var(--dor);border-color:var(--dor);color:var(--az);}
.msec{display:none;padding:0 14px 20px;}
.msec.a{display:block;}
.grupos-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;padding-top:4px;}
.grupo-card{background:var(--card);border:1px solid rgba(139,92,246,0.15);border-radius:var(--rad);overflow:hidden;}
.grupo-hdr{background:rgba(24,24,27,0.6);padding:8px 10px;display:flex;justify-content:space-between;align-items:center;}
.grupo-title{font-size:12px;font-weight:700;color:var(--dor);}
.grupo-body{padding:4px 0;}
.grupo-eq{display:flex;align-items:center;gap:6px;padding:5px 10px;font-size:11px;border-bottom:1px solid rgba(255,255,255,0.03);}
.grupo-eq:last-child{border-bottom:none;}
.grupo-eq.top{background:rgba(46,204,113,0.07);}
.partido-row{display:flex;align-items:center;background:rgba(0,0,0,0.25);border:1px solid rgba(139,92,246,0.12);border-radius:8px;padding:9px 12px;margin-bottom:6px;gap:10px;}
.partido-row.live{border-color:var(--roj);background:rgba(231,76,60,0.07);}
.p-hora{font-size:10px;color:var(--cel);min-width:38px;text-align:center;font-weight:600;}
.p-badge{font-size:8px;font-weight:700;padding:2px 5px;border-radius:3px;}
.p-badge.live{background:var(--roj);color:#fff;}
.p-badge.pronto{background:rgba(139,92,246,0.2);color:var(--cel);}
.p-badge.fin{background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.4);}
.p-teams{flex:1;display:flex;align-items:center;gap:6px;justify-content:center;}
.p-team{display:flex;align-items:center;gap:4px;font-size:12px;font-weight:600;}
.p-team.r{flex-direction:row-reverse;}
.p-score{font-size:18px;font-weight:700;min-width:52px;text-align:center;color:var(--dor);}
.p-score.pend{font-size:12px;color:rgba(255,255,255,0.25);}
.p-grp{font-size:9px;color:rgba(255,255,255,0.25);min-width:32px;text-align:right;}
.fecha-sep{font-size:10px;font-weight:700;color:rgba(255,255,255,0.3);padding:10px 0 6px;text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid rgba(139,92,246,0.08);margin-bottom:6px;}

/* Chat */
#chat-msgs{flex:1;overflow-y:auto;padding:10px 14px;display:flex;flex-direction:column;gap:6px;scrollbar-width:thin;}
.msg{display:flex;gap:6px;animation:fadeIn .2s;}
@keyframes fadeIn{from{opacity:0;transform:translateY(3px)}to{opacity:1}}
.msg-nick{color:var(--dor);font-weight:700;font-size:12px;white-space:nowrap;flex-shrink:0;}
.msg-txt{color:rgba(255,255,255,.85);font-size:13px;line-height:1.4;word-break:break-word;}
#chat-form{display:flex;padding:8px 14px;gap:8px;background:var(--az2);border-top:1px solid rgba(139,92,246,0.1);}
#chat-in{flex:1;background:var(--card);border:1px solid rgba(139,92,246,0.2);color:var(--txt);padding:9px 14px;border-radius:20px;font-size:13px;outline:none;}
#chat-btn{background:var(--cel);border:none;color:var(--az);font-weight:700;font-size:13px;padding:0 16px;border-radius:20px;cursor:pointer;}

/* Toast */
#toast{position:fixed;bottom:74px;left:50%;transform:translateX(-50%) translateY(60px);background:rgba(10,22,40,0.95);border:1px solid var(--cel);color:#fff;padding:9px 18px;border-radius:20px;font-size:13px;transition:transform .3s;z-index:999;backdrop-filter:blur(8px);white-space:nowrap;pointer-events:none;}
#toast.show{transform:translateX(-50%) translateY(0);}

/* Bottom nav */
#bnav{display:flex;background:var(--az2);border-top:1px solid rgba(139,92,246,0.12);padding:20px 0 20px;flex-shrink:0;}
.bi{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;}
.bi svg{width:20px;height:20px;}
.bl{font-size:9px;font-weight:700;color:var(--muted);}
.bl.a{color:var(--dor);}

/* Modal apodo */
#modal-nick{position:fixed;inset:0;background:var(--az);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;padding:24px;}
#modal-nick h1{font-size:24px;color:var(--cel);text-align:center;}
#nick-in{padding:11px 16px;border-radius:8px;border:2px solid var(--cel);background:var(--card);color:#fff;font-size:16px;width:100%;max-width:280px;outline:none;text-align:center;}
#nick-btn{background:var(--dor);border:none;padding:12px 44px;border-radius:8px;font-weight:700;font-size:15px;cursor:pointer;color:var(--az);}

/* PWA install */
#btn-instalar{display:none;position:fixed;bottom:72px;right:14px;background:var(--dor);color:var(--az);border:none;padding:11px 18px;border-radius:22px;font-weight:700;font-size:12px;cursor:pointer;z-index:99;box-shadow:0 4px 16px rgba(0,0,0,0.4);align-items:center;gap:7px;}
#ios-banner{display:none;position:fixed;bottom:0;left:0;right:0;background:var(--az2);border-top:2px solid var(--dor);padding:14px 40px 14px 14px;z-index:99;font-size:13px;}
#ios-banner strong{color:var(--dor);}
#ios-close{position:absolute;top:10px;right:12px;background:none;border:none;color:rgba(255,255,255,.4);font-size:18px;cursor:pointer;}

@media(min-width:600px){
  body{width:100%;}
  #player-hero{max-height:236px;}
}

html,body{height:100%;overflow:hidden;background:var(--bg);}
#hdr{background:var(--az2);border-bottom:1.5px solid var(--borde);}
.ntab.a{color:var(--dor);border-bottom-color:var(--dor);}
.cat-pill.all{background:var(--dor);color:#18181b;border-color:var(--dor);}
.q-btn.a{background:var(--dor);border-color:var(--dor);color:#18181b;}
#hero-badge{background:var(--roj);}
</style>
</head>
<body>

<!-- inicio NAV LATERAL                                                 -->

<div class="flex min-h-screen">

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- NAV LATERAL                                                 -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <aside id="sidebar"
    class="fixed top-0 left-0 z-40 h-full w-56 bg-zinc-900/95 border-r border-zinc-800/60 backdrop-blur-md
           flex flex-col transition-transform duration-300
           -translate-x-full lg:translate-x-0">

    <!-- Logo -->
    <div class="px-5 py-6 border-b border-zinc-800/60">
      <a href="/" class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-violet-600 to-violet-800 flex items-center justify-center font-black text-white text-base shadow-lg shadow-violet-900/40">S</div>
        <div>
          <p class="font-bold text-white text-base leading-none">StreamX</p>
          <p class="text-[10px] text-zinc-500 mt-0.5">TECNOCOM</p>
        </div>
      </a>
    </div>

    <!-- Nav links -->
    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">

      <a href="/" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all
        <%= (!activeType || activeType === '') && !activeGenre && !searchQuery ? 'bg-violet-600/20 text-violet-300 border border-violet-500/20' : 'text-zinc-400 hover:text-white hover:bg-zinc-800/60' %>">
        <svg class="w-4.5 h-4.5 shrink-0" style="width:18px;height:18px" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
